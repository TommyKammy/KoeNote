<Window x:Class="KoeNote.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KoeNote.App.Controls"
        mc:Ignorable="d"
        Title="KoeNote" Height="820" Width="1360" MinHeight="720" MinWidth="1080"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Background="#F8F9FA"
        FontFamily="Yu Gothic UI"
        AllowDrop="True"
        DragOver="OnDragOverAudioFiles"
        Drop="OnDropAudioFiles">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="104" />
            <RowDefinition Height="*" MinHeight="320" />
            <RowDefinition Height="8" />
            <RowDefinition Height="220" MinHeight="150" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <controls:HeaderToolbar Grid.Row="0" />

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="300" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <controls:JobListPanel Grid.Column="0" Margin="0,0,8,0" />
            <controls:TranscriptPanel Grid.Column="1" Margin="0,0,8,0" />
            <controls:ReviewPanel Grid.Column="2" />
        </Grid>

        <GridSplitter Grid.Row="2"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{StaticResource BorderBrushSoft}"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      ToolTip="ログ、モデル、セットアップ領域の高さを変更します" />

        <Grid Grid.Row="3" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:StageProgressPanel Grid.Column="0" Margin="0,0,8,0" />
            <controls:LogPanel Grid.Column="1" />
        </Grid>

        <controls:StatusBarPanel Grid.Row="4" />

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Panel.ZIndex="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="380"
                Margin="0,14,18,0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Visibility="{Binding HasModelDownloadNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#22C55E" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2" />
                            <Setter Property="BorderBrush" Value="#EF4444" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           VerticalAlignment="Top"
                           Margin="0,0,8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE930;" />
                            <Setter Property="Foreground" Value="#15803D" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                                    <Setter Property="Text" Value="&#xE711;" />
                                    <Setter Property="Foreground" Value="#B91C1C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="1"
                           Text="{Binding ModelDownloadNotification}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#14532D" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                                    <Setter Property="Foreground" Value="#7F1D1D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.RowSpan="3"
              Panel.ZIndex="10"
              Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#66000000" />
            <Border Width="780"
                    MaxWidth="980"
                    HorizontalAlignment="Right"
                    Margin="0,12,18,12"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DetailPanelTitle}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Command="{Binding CloseDetailPanelCommand}" Padding="9,7" MinWidth="0" ToolTip="閉じる">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </Grid>
                    <TabControl BorderThickness="0"
                                Background="Transparent"
                                SelectedIndex="{Binding SelectedDetailPanelTabIndex, Mode=TwoWay}">
                        <TabItem Header="設定">
                            <controls:SettingsTab />
                        </TabItem>
                        <TabItem Header="セットアップ">
                            <controls:SetupWizardTab />
                        </TabItem>
                        <TabItem Header="モデル">
                            <controls:ModelCatalogTab />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="0"
              Grid.RowSpan="5"
              Panel.ZIndex="30"
              Visibility="{Binding IsSetupWizardModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#990F172A" />
            <Border Width="960"
                    MaxWidth="1120"
                    MaxHeight="720"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SetupWizardModalTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SetupWizardModalGuide}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextWrapping="Wrap"
                                       Margin="0,7,22,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseSetupWizardModalCommand}"
                                Padding="9,7"
                                MinWidth="0"
                                VerticalAlignment="Top"
                                ToolTip="あとで設定する">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </Grid>

                    <Border DockPanel.Dock="Bottom"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,1,0,0"
                            Padding="0,14,0,0"
                            Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SetupStatusSummary}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                <Button Command="{Binding CloseSetupWizardModalCommand}" Padding="12,8">
                                    <TextBlock Text="あとで" />
                                </Button>
                                <Button Command="{Binding SetupBackCommand}"
                                        Padding="12,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                                        <TextBlock Text="戻る" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetupNextCommand}"
                                        Padding="12,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="次へ" />
                                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetupCompleteCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="13,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="完了" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <controls:SetupWizardTab />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
