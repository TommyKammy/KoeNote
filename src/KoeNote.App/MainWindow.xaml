<Window x:Class="KoeNote.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KoeNote.App.Controls"
        mc:Ignorable="d"
        Title="KoeNote" Height="820" Width="1360" MinHeight="720" MinWidth="1080"
        Icon="pack://siteoforigin:,,,/Resources/AppIcon.ico"
        Background="#F8F9FA"
        FontFamily="Meiryo UI"
        AllowDrop="True"
        DragOver="OnDragOverAudioFiles"
        Drop="OnDropAudioFiles"
        Closing="OnWindowClosing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" MinHeight="420" />
            <RowDefinition Height="144" MinHeight="132" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <controls:HeaderToolbar Grid.Row="0" />

        <ScrollViewer x:Name="MainContentScrollViewer"
                      Grid.Row="1"
                      Grid.RowSpan="2"
                      Margin="10,10,10,10"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid Width="{Binding ViewportWidth, ElementName=MainContentScrollViewer}"
                  Height="{Binding ViewportHeight, ElementName=MainContentScrollViewer}">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding MainContentZoomScale}"
                                    ScaleY="{Binding MainContentZoomScale}" />
                </Grid.LayoutTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" MinWidth="176" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="15*" MinWidth="540" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="6*" MinWidth="300" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="420" />
                    <RowDefinition Height="144" MinHeight="132" />
                </Grid.RowDefinitions>

                <controls:JobListPanel Grid.RowSpan="2" Grid.Column="0" />
                <GridSplitter Grid.RowSpan="2"
                              Grid.Column="1"
                              Style="{StaticResource ModernVerticalGridSplitter}" />
                <controls:TranscriptPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,8" />
                <GridSplitter Grid.RowSpan="2"
                              Grid.Column="3"
                              Style="{StaticResource ModernVerticalGridSplitter}" />
                <controls:ReviewPanel Grid.Column="4" Grid.Row="0" Margin="0,0,0,8" />
                <controls:TranscriptAudioPlayer Grid.Column="2" Grid.Row="1" />
                <controls:StageProgressPanel Grid.Column="4" Grid.Row="1" />
            </Grid>
        </ScrollViewer>

        <controls:StatusBarPanel Grid.Row="3" />

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Panel.ZIndex="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="380"
                Margin="0,14,18,0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Visibility="{Binding HasModelDownloadNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#ECFDF5" />
                    <Setter Property="BorderBrush" Value="#22C55E" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2" />
                            <Setter Property="BorderBrush" Value="#EF4444" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           VerticalAlignment="Top"
                           Margin="0,0,8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE930;" />
                            <Setter Property="Foreground" Value="#15803D" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                                    <Setter Property="Text" Value="&#xE711;" />
                                    <Setter Property="Foreground" Value="#B91C1C" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="1"
                           Text="{Binding ModelDownloadNotification}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#14532D" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModelDownloadNotificationError}" Value="True">
                                    <Setter Property="Foreground" Value="#7F1D1D" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Panel.ZIndex="21"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="420"
                Margin="0,68,18,0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Visibility="{Binding HasUpdateNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#60A5FA" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUpdateMandatory}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2" />
                            <Setter Property="BorderBrush" Value="#EF4444" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE895;"
                           FontSize="16"
                           Foreground="#2563EB"
                           VerticalAlignment="Top"
                           Margin="0,1,9,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding UpdateNotificationTitle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding UpdateNotificationMessage}"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,6" />
                    <TextBlock Text="{Binding UpdateDownloadProgressText}"
                               FontSize="11"
                               Foreground="#2563EB"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding DownloadUpdateCommand}"
                                Padding="9,5"
                                MinWidth="0"
                                ToolTip="Download and SHA256 verify update"
                                Visibility="{Binding CanShowUpdateDownloadAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0" />
                                <TextBlock Text="Download" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenUpdateReleaseNotesCommand}"
                                Padding="9,5"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                ToolTip="Open release notes">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0" />
                                <TextBlock Text="Release notes" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding InstallVerifiedUpdateCommand}"
                                Padding="9,5"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                ToolTip="Start SHA256 verified update installer"
                                Visibility="{Binding CanShowInstallUpdateAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0" />
                                <TextBlock Text="Install" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DismissUpdateNotificationCommand}"
                                Padding="9,5"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                ToolTip="Dismiss update notice">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0" />
                                <TextBlock Text="Later" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.RowSpan="2"
              Panel.ZIndex="10"
              Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#66000000" />
            <Border Width="780"
                    MaxWidth="980"
                    HorizontalAlignment="Right"
                    Margin="0,12,18,12"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DetailPanelTitle}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Command="{Binding CloseDetailPanelCommand}" Padding="9,7" MinWidth="0" ToolTip="閉じる">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </Grid>
                    <TabControl BorderThickness="0"
                                Background="Transparent"
                                SelectedIndex="{Binding SelectedDetailPanelTabIndex, Mode=TwoWay}">
                        <TabItem Header="設定">
                            <controls:SettingsTab />
                        </TabItem>
                        <TabItem Header="セットアップ">
                            <controls:SetupWizardTab />
                        </TabItem>
                        <TabItem Header="モデル">
                            <controls:ModelCatalogTab />
                        </TabItem>
                        <TabItem Header="ログ">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="範囲" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox Width="160"
                                                  ItemsSource="{Binding DiagnosticLogScopes}"
                                                  SelectedItem="{Binding SelectedDiagnosticLogScope, Mode=TwoWay}" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Padding="10,6"
                                            Command="{Binding OpenLogFolderCommand}"
                                            ToolTip="ローカルログフォルダを開きます">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                                            <TextBlock Text="フォルダ" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="3"
                                            Margin="8,0,0,0"
                                            Padding="10,6"
                                            Command="{Binding ExportLogsCommand}"
                                            ToolTip="診断パッケージを出力します">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" />
                                            <TextBlock Text="ログ出力" FontSize="12" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <controls:LogEntriesTab />
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="0"
              Grid.RowSpan="4"
              Panel.ZIndex="30"
              Visibility="{Binding IsSetupWizardModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#990F172A" />
            <Border Width="960"
                    MaxWidth="1120"
                    MaxHeight="720"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SetupWizardModalTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SetupWizardModalGuide}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextWrapping="Wrap"
                                       Margin="0,7,22,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseSetupWizardModalCommand}"
                                Padding="9,7"
                                MinWidth="0"
                                VerticalAlignment="Top"
                                ToolTip="あとで設定する">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </Grid>

                    <Border DockPanel.Dock="Bottom"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="0,1,0,0"
                            Padding="0,14,0,0"
                            Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SetupStatusSummary}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                                <Button Command="{Binding CloseSetupWizardModalCommand}" Padding="12,8">
                                    <TextBlock Text="あとで" />
                                </Button>
                                <Button Command="{Binding SetupBackCommand}"
                                        Padding="12,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                                        <TextBlock Text="戻る" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetupNextCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        ToolTip="{Binding SetupNextActionText}"
                                        Padding="12,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SetupNextActionText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                        <TextBlock Text="&#xE72A;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetupCancelInstallCommand}"
                                        Visibility="{Binding IsModelDownloadInProgress, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Padding="12,8"
                                        Margin="8,0,0,0"
                                        ToolTip="導入をキャンセルしてプリセット選択に戻ります">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                                        <TextBlock Text="キャンセル" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetupCompleteCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Visibility="{Binding ShowSetupCompleteAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Padding="13,8"
                                        Margin="8,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding SetupCompleteActionText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <controls:SetupWizardTab />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
