<Window x:Class="KoeNote.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KoeNote.App.Controls"
        mc:Ignorable="d"
        Title="KoeNote" Height="860" Width="1440" MinHeight="760" MinWidth="1180"
        Icon="pack://application:,,,/Resources/AppIcon.ico"
        Background="#F8F9FA"
        FontFamily="Yu Gothic UI"
        AllowDrop="True"
        DragOver="OnDragOverAudioFiles"
        Drop="OnDropAudioFiles">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="104" />
            <RowDefinition Height="*" />
            <RowDefinition Height="176" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <controls:HeaderToolbar Grid.Row="0" />

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <controls:JobListPanel Grid.Column="0" Margin="0,0,14,0" />
            <controls:TranscriptPanel Grid.Column="1" Margin="0,0,14,0" />
            <controls:ReviewPanel Grid.Column="2" />
        </Grid>

        <Grid Grid.Row="2" Margin="18,0,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="510" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:StageProgressPanel Grid.Column="0" Margin="0,0,14,0" />
            <controls:LogPanel Grid.Column="1" />
        </Grid>

        <controls:StatusBarPanel Grid.Row="3" />
    </Grid>
</Window>
