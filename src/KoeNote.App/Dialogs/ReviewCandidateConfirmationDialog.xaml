<Window x:Class="KoeNote.App.Dialogs.ReviewCandidateConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="整文候補を確認"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Meiryo UI"
        Loaded="OnLoaded"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="CountPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="DetailBox" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#DDE5EE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="6"
                              Opacity="0.18"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        CornerRadius="19"
                        Background="#EFF6FF">
                    <TextBlock Text="&#xE8F1;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#2563EB"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0">
                    <TextBlock Text="整文候補を確認"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding LeadText}"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="19" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,16,0,12">
                <Border Style="{StaticResource CountPill}">
                    <TextBlock Text="{Binding PendingCountText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#1D4ED8" />
                </Border>
                <Border Style="{StaticResource CountPill}">
                    <TextBlock Text="{Binding AcceptedCountText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#15803D" />
                </Border>
                <Border Style="{StaticResource CountPill}">
                    <TextBlock Text="{Binding RejectedCountText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#B91C1C" />
                </Border>
                <Border Style="{StaticResource CountPill}">
                    <TextBlock Text="{Binding EditedCountText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#7C3AED" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CandidateListTitle}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="4,2,4,8" />
                        <ListBox ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10"
                                            Background="#FFFFFF"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding TimestampText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0F766E" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ConfidenceText}"
                                                           FontSize="11"
                                                           Foreground="#475569" />
                                            </Grid>
                                            <TextBlock Text="{Binding SpeakerText}"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding IssueType}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="{Binding SuggestedText}"
                                                       Margin="0,7,0,0"
                                                       FontSize="12"
                                                       Foreground="#1E3A8A"
                                                       TextWrapping="Wrap"
                                                       LineHeight="18"
                                                       MaxHeight="54" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#FFFFFF"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding DetailTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding DetailSubtitle}"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentPositionText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#2563EB"
                                       VerticalAlignment="Top" />
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="現在の本文"
                                           Style="{StaticResource DetailLabel}" />
                                <Border Style="{StaticResource DetailBox}">
                                    <TextBlock Text="{Binding SelectedItem.CurrentText}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               LineHeight="20"
                                               Foreground="#334155" />
                                </Border>

                                <TextBlock Text="整文候補"
                                           Style="{StaticResource DetailLabel}" />
                                <Border Style="{StaticResource DetailBox}"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE">
                                    <TextBlock Text="{Binding SelectedItem.SuggestedText}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               LineHeight="20"
                                               Foreground="#1E3A8A" />
                                </Border>

                                <TextBlock Text="候補理由"
                                           Style="{StaticResource DetailLabel}" />
                                <Border Style="{StaticResource DetailBox}">
                                    <TextBlock Text="{Binding SelectedItem.Reason}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               LineHeight="19"
                                               Foreground="#475569" />
                                </Border>

                                <TextBlock Text="手修正"
                                           Style="{StaticResource DetailLabel}" />
                                <TextBox Text="{Binding ManualEditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="96"
                                         MaxHeight="150"
                                         Padding="10"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         IsEnabled="{Binding CanOperate}" />
                                <TextBlock Text="{Binding OperationErrorText}"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="#B91C1C"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasOperationError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="前へ"
                                        Width="72"
                                        Padding="0,7"
                                        IsEnabled="{Binding CanGoPrevious}"
                                        Click="OnPreviousClick" />
                                <Button Content="次へ"
                                        Width="72"
                                        Padding="0,7"
                                        Margin="8,0,0,0"
                                        IsEnabled="{Binding CanGoNext}"
                                        Click="OnNextClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="却下"
                                        Width="76"
                                        Padding="0,7"
                                        IsEnabled="{Binding CanOperate}"
                                        Click="OnRejectClick" />
                                <Button Content="採用"
                                        Width="76"
                                        Padding="0,7"
                                        Margin="8,0,0,0"
                                        Background="#16A34A"
                                        BorderBrush="#16A34A"
                                        Foreground="#FFFFFF"
                                        FontWeight="SemiBold"
                                        IsEnabled="{Binding CanOperate}"
                                        Click="OnAcceptClick" />
                                <Button Content="手修正を適用"
                                        Width="116"
                                        Padding="0,7"
                                        Margin="8,0,0,0"
                                        Background="#4F46E5"
                                        BorderBrush="#4F46E5"
                                        Foreground="#FFFFFF"
                                        FontWeight="SemiBold"
                                        IsEnabled="{Binding CanApplyManualEdit}"
                                        Click="OnApplyManualEditClick" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3"
                  Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding FooterText}"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="キャンセル"
                            Width="96"
                            Padding="0,8"
                            Click="OnCancelClick" />
                    <Button Content="後で確認"
                            Width="96"
                            Padding="0,8"
                            Margin="8,0,0,0"
                            Click="OnDeferClick" />
                    <Button Content="話者確認へ進む"
                            Width="132"
                            Padding="0,8"
                            Margin="8,0,0,0"
                            Background="#2563EB"
                            BorderBrush="#2563EB"
                            Foreground="#FFFFFF"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding CanContinue}"
                            Click="OnContinueClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
