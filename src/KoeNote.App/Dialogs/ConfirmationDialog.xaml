<Window x:Class="KoeNote.App.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Meiryo UI">
    <Border Background="#FFFFFF"
            BorderBrush="#DDE5EE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="18"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="6"
                              Opacity="0.18"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        CornerRadius="17"
                        Background="{Binding IconBackground}">
                    <TextBlock Text="{Binding IconGlyph}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Foreground="{Binding IconForeground}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0">
                    <TextBlock Text="{Binding Heading}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding Message}"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="19" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Height="1"
                    Background="#EEF0F2"
                    Margin="0,18,0,14" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{Binding CancelText}"
                        Width="96"
                        Padding="0,8"
                        Click="OnCancelClick" />
                <Button Content="{Binding ConfirmText}"
                        Width="96"
                        Padding="0,8"
                        Margin="8,0,0,0"
                        Background="{Binding ConfirmBackground}"
                        BorderBrush="{Binding ConfirmBorderBrush}"
                        Foreground="{Binding ConfirmForeground}"
                        FontWeight="SemiBold"
                        Click="OnConfirmClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
