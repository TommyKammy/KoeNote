<Window x:Class="KoeNote.App.Dialogs.ReadableSpeakerRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="話者名を変更"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Meiryo UI"
        PreviewKeyDown="OnPreviewKeyDown">
    <Border Background="#FFFFFF"
            BorderBrush="#DDE5EE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="6"
                              Opacity="0.16"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="話者名を変更"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#111827" />

            <TextBlock Grid.Row="1"
                       Margin="0,8,0,16"
                       Text="同じジョブ内の同じ話者名をまとめて更新します。"
                       FontSize="12"
                       Foreground="#64748B" />

            <StackPanel Grid.Row="2">
                <TextBlock Text="現在の話者名"
                           FontSize="12"
                           Foreground="#64748B" />
                <TextBlock x:Name="CurrentSpeakerText"
                           Margin="0,4,0,12"
                           Padding="10,6"
                           Background="#F1F5F9"
                           Foreground="#111827" />

                <TextBlock Text="変更後の話者名"
                           FontSize="12"
                           Foreground="#64748B" />
                <TextBox x:Name="SpeakerNameTextBox"
                         Margin="0,4,0,0"
                         MinHeight="36"
                         Padding="10,7"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         FontSize="14" />
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Margin="0,20,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="キャンセル"
                        Width="96"
                        MinHeight="34"
                        Margin="0,0,8,0"
                        Click="OnCancelClick" />
                <Button Content="変更"
                        Width="96"
                        MinHeight="34"
                        Background="#16A34A"
                        BorderBrush="#16A34A"
                        Foreground="#FFFFFF"
                        FontWeight="SemiBold"
                        Click="OnApplyClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
