<Window x:Class="KoeNote.App.Dialogs.SpeakerNameConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="話者名を確認"
        Width="760"
        SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Meiryo UI"
        Loaded="OnLoaded"
        Closed="OnClosed"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PreviewPlayButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#ECFDF5" />
            <Setter Property="BorderBrush" Value="#BBF7D0" />
            <Setter Property="Foreground" Value="#15803D" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTip" Value="この代表発話を再生" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DCFCE7" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#86EFAC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#BBF7D0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4ADE80" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#DDE5EE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="6"
                              Opacity="0.18"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        CornerRadius="19"
                        Background="#ECFDF5">
                    <TextBlock Text="&#xE77B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#15803D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0">
                    <TextBlock Text="整文前に話者名を確認"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding LeadText}"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="19" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,12"
                    Padding="12,10"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock Text="このジョブに保存して整文へ反映します。Speaker_0 などのIDが残っている場合は、代表発話を聞きながら担当者名や役割名に直してください。"
                           FontSize="12"
                           Foreground="#334155"
                           TextWrapping="Wrap"
                           LineHeight="19" />
            </Border>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="410"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,14,0">
                                        <TextBlock Text="{Binding OriginalLabel}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding OriginalLabel}" />
                                        <TextBlock Text="{Binding SegmentCountText}"
                                                   Margin="0,5,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding AssistanceText}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="#0F766E"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasAssistanceText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1">
                                        <TextBlock Text="整文に使う名前"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="36"
                                                 MaxLength="80"
                                                 Padding="9,6"
                                                 Margin="0,5,0,0"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="OnDisplayNameTextChanged" />
                                        <TextBlock Text="{Binding ErrorText}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="#B91C1C"
                                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,10,0,0"
                                            Padding="10,8"
                                            Background="#F9FAFB"
                                            BorderBrush="#EEF0F2"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="代表発話"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,0,0,6" />
                                            <ItemsControl ItemsSource="{Binding PreviewItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="PreviewRow"
                                                                Margin="0,0,0,6"
                                                                Padding="8"
                                                                Background="#FFFFFF"
                                                                BorderBrush="#E5E7EB"
                                                                BorderThickness="1"
                                                                CornerRadius="5">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <Button Grid.Row="0"
                                                                        Grid.Column="0"
                                                                        Style="{StaticResource PreviewPlayButton}"
                                                                        Content="{Binding PlayIcon}"
                                                                        Command="{Binding PlayCommand}" />
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="1"
                                                                           Text="{Binding TimestampText}"
                                                                           FontSize="11"
                                                                           Foreground="#0F766E"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0" />
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="2"
                                                                           Text="{Binding Text}"
                                                                           FontSize="12"
                                                                           Foreground="#475569"
                                                                           TextWrapping="Wrap"
                                                                           LineHeight="18"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="3"
                                                                           Text="{Binding PlaybackStatusText}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#15803D"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,0,0" />
                                                                <ProgressBar Grid.Row="1"
                                                                             Grid.Column="1"
                                                                             Grid.ColumnSpan="3"
                                                                             Height="3"
                                                                             Margin="0,7,0,0"
                                                                             Minimum="0"
                                                                             Maximum="100"
                                                                             Value="{Binding PlaybackProgressPercent, Mode=OneWay}"
                                                                             Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                <Setter TargetName="PreviewRow" Property="Background" Value="#ECFDF5" />
                                                                <Setter TargetName="PreviewRow" Property="BorderBrush" Value="#86EFAC" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="3"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding ValidationSummary}"
                           FontSize="12"
                           Foreground="#B91C1C"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="あとで設定"
                            Width="108"
                            Padding="0,8"
                            Click="OnCancelClick" />
                    <Button Content="保存して整文開始"
                            Width="136"
                            Padding="0,8"
                            Margin="8,0,0,0"
                            Background="#16A34A"
                            BorderBrush="#16A34A"
                            Foreground="#FFFFFF"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding CanConfirm}"
                            Click="OnConfirmClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
