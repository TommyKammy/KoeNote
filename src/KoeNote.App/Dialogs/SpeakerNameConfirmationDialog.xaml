<Window x:Class="KoeNote.App.Dialogs.SpeakerNameConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="話者名を確認"
        Width="720"
        SizeToContent="Height"
        MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Meiryo UI"
        Loaded="OnLoaded"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="#DDE5EE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="6"
                              Opacity="0.18"
                              Color="#111827" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        CornerRadius="19"
                        Background="#ECFDF5">
                    <TextBlock Text="&#xE77B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#15803D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0">
                    <TextBlock Text="整文前に話者名を確認"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding LeadText}"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="19" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,12"
                    Padding="12,10"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock Text="このジョブに保存して整文へ反映します。Speaker_0 などのIDが残っている場合は、担当者名や役割名に直してください。"
                           FontSize="12"
                           Foreground="#334155"
                           TextWrapping="Wrap"
                           LineHeight="19" />
            </Border>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="390"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,14,0">
                                        <TextBlock Text="{Binding OriginalLabel}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding OriginalLabel}" />
                                        <TextBlock Text="{Binding SegmentCountText}"
                                                   Margin="0,5,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding AssistanceText}"
                                                   Margin="0,6,0,0"
                                                   FontSize="11"
                                                   Foreground="#0F766E"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasAssistanceText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1">
                                        <TextBlock Text="整文に使う名前"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="36"
                                                 MaxLength="80"
                                                 Padding="9,6"
                                                 Margin="0,5,0,0"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="OnDisplayNameTextChanged" />
                                        <TextBlock Text="{Binding ErrorText}"
                                                   Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="#B91C1C"
                                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Margin="0,10,0,0"
                                            Padding="10,8"
                                            Background="#F9FAFB"
                                            BorderBrush="#EEF0F2"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <TextBlock Text="{Binding PreviewText}"
                                                   FontSize="12"
                                                   Foreground="#475569"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"
                                                   MaxHeight="74" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="3"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding ValidationSummary}"
                           FontSize="12"
                           Foreground="#B91C1C"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="あとで設定"
                            Width="108"
                            Padding="0,8"
                            Click="OnCancelClick" />
                    <Button Content="保存して整文開始"
                            Width="136"
                            Padding="0,8"
                            Margin="8,0,0,0"
                            Background="#16A34A"
                            BorderBrush="#16A34A"
                            Foreground="#FFFFFF"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding CanConfirm}"
                            Click="OnConfirmClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
