<Application x:Class="KoeNote.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KoeNote.App"
             xmlns:converters="clr-namespace:KoeNote.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:SpeakerChipBrushConverter x:Key="SpeakerChipBrushConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
