<UserControl x:Class="KoeNote.App.Controls.ReadablePolishedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenReadableDocumentBlocks" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoReadableDocumentBlocks" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0"
          Background="Transparent">
        <Grid>
            <Border MaxWidth="1080"
                    HorizontalAlignment="Stretch"
                    Background="#FFFFFF"
                    BorderBrush="#D6DAE1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="46,38"
                    Style="{StaticResource VisibleWhenReadableDocumentBlocks}">
                <ScrollViewer x:Name="ReadableDocumentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0">
                    <StackPanel x:Name="ReadableDocumentBlocksPanel" />
                </ScrollViewer>
            </Border>

            <Grid Style="{StaticResource VisibleWhenNoReadableDocumentBlocks}">
                <Border MaxWidth="760"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="44,40"
                        Background="#FBFCFD"
                        BorderBrush="#D6DAE1"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="{Binding ReadableDocumentStateTitle}"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#171C27"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding ReadableDocumentStateDescription}"
                                   Margin="0,12,0,0"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="{Binding ReadableDocumentFontSize}"
                                   LineHeight="{Binding ReadableDocumentLineHeight}"
                                   Foreground="#646C7B"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
