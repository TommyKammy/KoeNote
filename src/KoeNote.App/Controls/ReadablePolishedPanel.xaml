<UserControl x:Class="KoeNote.App.Controls.ReadablePolishedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenReadableDocumentBlocks" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoReadableDocumentBlocks" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableDocumentChrome" TargetType="Border">
            <Setter Property="MaxWidth" Value="1080" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D6DAE1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="46,38" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDetailLayout}" Value="True">
                    <Setter Property="MaxWidth" Value="1600" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="Padding" Value="30,28,30,32" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableDocumentVisibleChrome" TargetType="Border" BasedOn="{StaticResource ReadableDocumentChrome}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableDocumentEmptyChrome" TargetType="Border">
            <Setter Property="MaxWidth" Value="760" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="44,40" />
            <Setter Property="Background" Value="#FBFCFD" />
            <Setter Property="BorderBrush" Value="#D6DAE1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDetailLayout}" Value="True">
                    <Setter Property="MaxWidth" Value="880" />
                    <Setter Property="Padding" Value="32,30" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0"
          Background="Transparent">
        <Grid>
            <Border Style="{StaticResource ReadableDocumentVisibleChrome}">
                <RichTextBox x:Name="ReadableDocumentRichTextBox"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             Margin="0"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             IsDocumentEnabled="True"
                             IsTabStop="False"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             FocusVisualStyle="{x:Null}" />
            </Border>

            <Grid Style="{StaticResource VisibleWhenNoReadableDocumentBlocks}">
                <Border Style="{StaticResource ReadableDocumentEmptyChrome}">
                    <StackPanel>
                        <TextBlock Text="{Binding ReadableDocumentStateTitle}"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#171C27"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding ReadableDocumentStateDescription}"
                                   Margin="0,12,0,0"
                                   FontFamily="Yu Gothic UI"
                                   FontSize="{Binding ReadableDocumentFontSize}"
                                   LineHeight="{Binding ReadableDocumentLineHeight}"
                                   Foreground="#646C7B"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
