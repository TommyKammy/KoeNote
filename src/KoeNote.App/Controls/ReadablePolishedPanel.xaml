<UserControl x:Class="KoeNote.App.Controls.ReadablePolishedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="VisibleWhenReadablePolishedContent" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadablePolishedContent}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoReadablePolishedContent" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadablePolishedContent}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                HorizontalAlignment="Right"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                CornerRadius="0"
                Padding="16,8"
                Margin="0">
            <WrapPanel>
                <Button Command="{Binding ShowRawTranscriptTabCommand}"
                        Padding="10,6"
                        MinWidth="0"
                        Margin="0,0,6,0"
                        ToolTip="ASR原文を確認・修正します"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="原文を確認"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowDiffTranscriptTabCommand}"
                        Padding="10,6"
                        MinWidth="0"
                        Margin="0,0,6,0"
                        ToolTip="素起こしとレビュー候補の差分を確認します"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8AB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="差分を見る"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding ShowReviewCandidateTranscriptTabCommand}"
                        Padding="10,6"
                        MinWidth="0"
                        ToolTip="最終整文前のレビュー候補を確認します"
                        Style="{StaticResource ToolbarButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE70F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="レビュー候補"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <Border x:Name="ReadablePolishedContentCard"
                Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0"
                CornerRadius="0"
                Padding="18">
            <Grid>
                <TextBox Text="{Binding ReadablePolishedContent, Mode=OneWay}"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         FontSize="{Binding ReadableDocumentFontSize}"
                         FontWeight="Normal"
                         Foreground="{StaticResource TextBrush}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Style="{StaticResource VisibleWhenReadablePolishedContent}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource VisibleWhenNoReadablePolishedContent}">
                    <TextBlock Text="{Binding ReadablePolishedContentDisplay}"
                               FontSize="{Binding ReadableDocumentFontSize}"
                               FontWeight="Normal"
                               LineHeight="{Binding ReadableDocumentLineHeight}"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap" />
                </ScrollViewer>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding CopyReadablePolishedContentCommand}"
                        Padding="10,6"
                        ToolTip="整文をコピー">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=ReadablePolishedContentCard}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasReadablePolishedContent}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="コピー"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
