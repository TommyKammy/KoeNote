<UserControl x:Class="KoeNote.App.Controls.StandardJobRailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="VisibleWhenStandardJobRailExpanded" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStandardJobRailExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenStandardJobRailCollapsed" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsStandardJobRailExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StandardJobRailIconButton" TargetType="Button" BasedOn="{StaticResource StandardRailButton}">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="StandardJobRailListBox" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="StandardJobRailListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RowChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="#F4F7F5" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="#D6DAE1" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="#E9F7EF" />
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="#15A350" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#FAFBFC"
            BorderBrush="#D6DAE1"
            BorderThickness="0,0,1,0"
            Padding="10,14">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top"
                        HorizontalAlignment="Stretch">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Style="{StaticResource VisibleWhenStandardJobRailExpanded}">
                        <Border Width="28"
                                Height="28"
                                CornerRadius="8"
                                Background="#E9F7EF"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding StandardLayoutJobBadgeText}"
                                       Foreground="#0F7A3D"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="ジョブ"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#171C27" />
                            <TextBlock Text="{Binding JobCountSummary}"
                                       FontSize="11"
                                       Foreground="#646C7B" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding ToggleStandardJobRailCommand}"
                            ToolTip="{Binding StandardJobRailToggleToolTip}"
                            Style="{StaticResource StandardJobRailIconButton}">
                        <TextBlock Text="{Binding StandardJobRailToggleText}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                    </Button>
                </Grid>

                <StackPanel HorizontalAlignment="Center"
                            Style="{StaticResource VisibleWhenStandardJobRailCollapsed}">
                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#E9F7EF"
                            Margin="0,0,0,8"
                            ToolTip="{Binding JobCountSummary}">
                        <TextBlock Text="{Binding StandardLayoutJobBadgeText}"
                                   Foreground="#0F7A3D"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Button Style="{StaticResource StandardJobRailIconButton}"
                            Command="{Binding AddAudioCommand}"
                            ToolTip="音声ファイルを追加">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                    <Button Style="{StaticResource StandardJobRailIconButton}"
                            Command="{Binding UseDetailLayoutCommand}"
                            ToolTip="詳細レイアウトでジョブ一覧を開く">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" />
                    </Button>
                </StackPanel>

                <StackPanel Style="{StaticResource VisibleWhenStandardJobRailExpanded}">
                    <Grid Height="28"
                          Margin="0,0,0,10"
                          Background="Transparent"
                          PreviewMouseLeftButtonDown="OnJobRailSearchBoxPreviewMouseLeftButtonDown">
                        <Border Background="#FFFFFF"
                                BorderBrush="#D6DAE1"
                                BorderThickness="1"
                                CornerRadius="14" />
                        <TextBox x:Name="JobRailSearchTextBox"
                                 Style="{StaticResource SearchPillTextBox}"
                                 Text="{Binding JobSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="ジョブ名で検索" />
                        <TextBlock Text="ジョブを検索"
                                   Foreground="#646C7B"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="36,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=JobRailSearchTextBox}" Value="" />
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=JobRailSearchTextBox}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="x"
                                Command="{Binding ClearJobSearchCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SearchClearButton}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=JobRailSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <UniformGrid Columns="3"
                                 Margin="0,0,0,12">
                        <Button Command="{Binding AddAudioCommand}"
                                ToolTip="音声ファイルを追加"
                                Padding="8,6"
                                MinWidth="0"
                                Style="{StaticResource ToolbarButton}">
                            <TextBlock Text="&#xE710;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" />
                        </Button>
                        <Button Command="{Binding ClearAllJobsCommand}"
                                ToolTip="ジョブ一覧をクリア履歴へ移動"
                                Padding="8,6"
                                MinWidth="0"
                                Margin="6,0"
                                Style="{StaticResource ToolbarButton}">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" />
                        </Button>
                        <Button Command="{Binding UseDetailLayoutCommand}"
                                ToolTip="詳細ジョブ一覧を開く"
                                Padding="8,6"
                                MinWidth="0"
                                Style="{StaticResource ToolbarButton}">
                            <TextBlock Text="&#xE8A5;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" />
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </StackPanel>

            <Border DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    MinHeight="70"
                    Cursor="Hand"
                    AllowDrop="True"
                    MouseLeftButtonUp="OnJobRailImportDropZoneClick"
                    ToolTip="音声ファイルをドラッグ&amp;ドロップ、またはクリックして追加">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource VisibleWhenStandardJobRailExpanded}">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="BorderBrush" Value="#C2C8D0" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Padding" Value="10" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#15A350" />
                                <Setter Property="Background" Value="#E9F7EF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ファイル追加"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#171C27"
                               TextAlignment="Center" />
                    <TextBlock Text="ドラッグ&amp;ドロップ"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="#0F7A3D"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding FilteredJobs}"
                     SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                     Style="{StaticResource StandardJobRailListBox}"
                     ItemContainerStyle="{StaticResource StandardJobRailListBoxItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Border Padding="9"
                                    Style="{StaticResource VisibleWhenStandardJobRailCollapsed}"
                                    ToolTip="{Binding Title}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="36"
                                            Height="36"
                                            CornerRadius="10"
                                            Background="#FFFFFF"
                                            BorderBrush="#D6DAE1"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding RailInitial}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#171C27"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <Border Width="36"
                                            Height="4"
                                            CornerRadius="2"
                                            Margin="0,6,0,0"
                                            Background="#15A350" />
                                    <TextBlock Text="{Binding UnreviewedDrafts, StringFormat={}{0}}"
                                               FontSize="10"
                                               Foreground="#95571F"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Padding="12"
                                    Background="#FFFFFF"
                                    Style="{StaticResource VisibleWhenStandardJobRailExpanded}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#171C27"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding DataContext.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Padding="5,1"
                                                MinWidth="24"
                                                ToolTip="このジョブをクリア履歴へ移動" />
                                    </Grid>
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="11"
                                               Foreground="#646C7B"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11"
                                                   Foreground="#646C7B"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                                   FontSize="11"
                                                   Foreground="#646C7B" />
                                    </Grid>
                                    <ProgressBar Value="{Binding ProgressPercent}"
                                                 Maximum="100"
                                                 Height="4"
                                                 Margin="0,0,0,7" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding UpdatedAtDisplay}"
                                                   FontSize="10"
                                                   Foreground="#8B93A2" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding UnreviewedDrafts, StringFormat=未確認 {0}}"
                                                   FontSize="10"
                                                   Foreground="#95571F" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
