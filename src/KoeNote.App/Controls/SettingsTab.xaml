<UserControl x:Class="KoeNote.App.Controls.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingsSection" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" MinWidth="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.9*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="モデル設定" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="ASRモデル" Style="{StaticResource SettingsFieldLabel}" />
                        <ComboBox ItemsSource="{Binding AvailableAsrEngines}"
                                  SelectedItem="{Binding SelectedSettingsAsrEngine, Mode=TwoWay}"
                                  DisplayMemberPath="SetupDisplayName"
                                  MinHeight="32"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="整文ステージを有効にする"
                                  IsChecked="{Binding EnableReviewStage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,10" />

                        <TextBlock Text="整文モデル" Style="{StaticResource SettingsFieldLabel}" />
                        <ComboBox ItemsSource="{Binding SetupReviewModelChoices}"
                                  SelectedItem="{Binding SelectedSettingsReviewModel, Mode=TwoWay}"
                                  DisplayMemberPath="SetupDisplayName"
                                  MinHeight="32"
                                  ToolTip="{Binding SelectedSettingsReviewModel.SetupDisplayName}"
                                  TextSearch.TextPath="SetupDisplayName" />

                        <TextBlock Text="Active LLM profile" Style="{StaticResource SettingsFieldLabel}" Margin="0,12,0,4" />
                        <TextBlock Text="{Binding LlmActiveProfileSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,8" />

                        <Expander Header="Task settings"
                                  IsExpanded="False"
                                  Style="{StaticResource CompactEditExpander}">
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="{Binding LlmReviewTaskSummary}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding LlmSummaryTaskSummary}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding LlmPolishingTaskSummary}"
                                           TextWrapping="Wrap"
                                           FontSize="12" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="読みやすく整文プロンプト" Style="{StaticResource SettingsSectionTitle}" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="対象モデル" Style="{StaticResource SettingsFieldLabel}" />
                                <ComboBox ItemsSource="{Binding ReadablePolishingPromptModelFamilyOptions}"
                                          SelectedItem="{Binding SelectedReadablePolishingPromptModelFamily, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          MinHeight="32" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="プリセット" Style="{StaticResource SettingsFieldLabel}" />
                                <ComboBox ItemsSource="{Binding ReadablePolishingPromptPresetOptions}"
                                          SelectedItem="{Binding SelectedReadablePolishingPromptPreset, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding IsReadablePolishingPromptPresetEnabled}"
                                          MinHeight="32" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding ReadablePolishingPromptPresetDescription}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{Binding ReadablePolishingPromptActiveModelFamilySummary}"
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Button Command="{Binding SelectActiveReadablePolishingPromptModelFamilyCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinHeight="30"
                                    Padding="10,4"
                                    Margin="8,0,0,0"
                                    ToolTip="現在の整文モデルに対応するプロンプト設定を表示します。">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8AB;"
                                               Style="{StaticResource IconText}"
                                               Foreground="#FFFFFF" />
                                    <TextBlock Text="表示"
                                               Foreground="#FFFFFF"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBox Text="{Binding ReadablePolishingPromptPreviewText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120"
                                 MaxHeight="220"
                                 Margin="0,0,0,10"
                                 ToolTip="表示ボタンで、現在選択されている読みやすく整文プロンプトの内容を確認できます。" />

                        <TextBlock Text="追加指示" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBox Text="{Binding ReadablePolishingPromptAdditionalInstruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="70"
                                 Margin="0,0,0,10"
                                 ToolTip="選択したプリセットに追加で反映したい指示を入力します。" />

                        <CheckBox Content="カスタムプロンプトを使う"
                                  IsChecked="{Binding ReadablePolishingPromptUseCustomPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8" />

                        <TextBox Text="{Binding ReadablePolishingPromptCustomPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="96"
                                 Margin="0,0,0,10"
                                 ToolTip="オンにすると、プリセットの代わりにこの本文を使います。出力形式などの必須ルールは自動で追加されます。" />

                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SaveReadablePolishingPromptSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinHeight="34"
                                    Padding="14,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;"
                                               Style="{StaticResource IconText}"
                                               Foreground="#FFFFFF" />
                                    <TextBlock Text="保存"
                                               Foreground="#FFFFFF"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ResetReadablePolishingPromptSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinHeight="34"
                                    Padding="14,6"
                                    Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;"
                                               Style="{StaticResource IconText}"
                                               Foreground="#FFFFFF" />
                                    <TextBlock Text="標準に戻す"
                                               Foreground="#FFFFFF"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="{Binding ReadablePolishingPromptSettingsStatus}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="ASR補助情報" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="コンテキスト" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBox Text="{Binding AsrContextText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="82"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="ホットワード" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBox Text="{Binding AsrHotwordsText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="62" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="状態" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="{Binding FirstRunSummary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding FirstRunDetail}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="セットアップ" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding SetupStatusSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="保存先" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding StoragePath}"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="メンテナンス" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="データベース" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding DatabaseMaintenanceSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,8" />
                        <Button Command="{Binding RunDatabaseMaintenanceCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                Margin="0,0,0,14"
                                ToolTip="SQLite データベースを VACUUM / ANALYZE で最適化します。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;"
                                           Style="{StaticResource IconText}"
                                           Foreground="#FFFFFF" />
                                <TextBlock Text="DBを最適化"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="クリーンアップ" Style="{StaticResource SettingsFieldLabel}" />
                        <Button Command="{Binding OpenCleanupToolCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                ToolTip="KoeNote クリーンアップツールを開きます。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           Style="{StaticResource IconText}"
                                           Foreground="#FFFFFF" />
                                <TextBlock Text="クリーンアップツールを開く"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
