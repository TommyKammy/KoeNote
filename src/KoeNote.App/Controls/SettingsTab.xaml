<UserControl x:Class="KoeNote.App.Controls.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingsSection" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" MinWidth="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.9*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="モデル設定" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="ASRモデル" Style="{StaticResource SettingsFieldLabel}" />
                        <ComboBox ItemsSource="{Binding AvailableAsrEngines}"
                                  SelectedValue="{Binding SelectedAsrEngineId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="EngineId"
                                  DisplayMemberPath="DisplayName"
                                  MinHeight="32"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="整文ステージを有効にする"
                                  IsChecked="{Binding EnableReviewStage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,10" />

                        <CheckBox Content="要約ステージを有効にする"
                                  IsChecked="{Binding EnableSummaryStage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,10" />

                        <TextBlock Text="整文モデル" Style="{StaticResource SettingsFieldLabel}" />
                        <ComboBox ItemsSource="{Binding SetupReviewModelChoices}"
                                  SelectedItem="{Binding SelectedSetupReviewModel, Mode=TwoWay}"
                                  DisplayMemberPath="SetupDisplayName"
                                  MinHeight="32"
                                  ToolTip="{Binding SelectedSetupReviewModel.SetupDisplayName}"
                                  TextSearch.TextPath="SetupDisplayName" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="ASR補助情報" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="コンテキスト" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBox Text="{Binding AsrContextText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="82"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="ホットワード" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBox Text="{Binding AsrHotwordsText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="62" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="辞書プリセット" Style="{StaticResource SettingsSectionTitle}" />

                        <Button Command="{Binding ImportDomainPresetCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                ToolTip="専門領域プリセット JSON を読み込みます。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;"
                                           Style="{StaticResource IconText}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="JSONを読み込み"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding LoadedDomainPresetSummary}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,6" />

                        <TextBox Text="{Binding LoadedDomainPresetDetails, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="110"
                                 MaxHeight="180"
                                 Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Command="{Binding ApplyLoadedDomainPresetCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinHeight="34"
                                    Padding="14,6"
                                    ToolTip="読み込み済みプリセットをインポートします。">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;"
                                               Style="{StaticResource IconText}"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="インポート"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ClearDomainPresetCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinHeight="34"
                                    Padding="14,6"
                                    Margin="8,0,0,0"
                                    ToolTip="選択したプリセットをクリアします。">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;"
                                               Style="{StaticResource IconText}"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="クリア"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="インポート履歴"
                                   Style="{StaticResource SettingsFieldLabel}" />
                        <ComboBox ItemsSource="{Binding DomainPresetImports}"
                                  SelectedItem="{Binding SelectedDomainPresetImport, Mode=TwoWay}"
                                  DisplayMemberPath="Summary"
                                  MinHeight="32" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="状態" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="{Binding FirstRunSummary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding FirstRunDetail}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="セットアップ" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding SetupStatusSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="保存先" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding StoragePath}"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <TextBlock Text="メンテナンス" Style="{StaticResource SettingsSectionTitle}" />

                        <TextBlock Text="データベース" Style="{StaticResource SettingsFieldLabel}" />
                        <TextBlock Text="{Binding DatabaseMaintenanceSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Margin="0,0,0,8" />
                        <Button Command="{Binding RunDatabaseMaintenanceCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                Margin="0,0,0,14"
                                ToolTip="SQLite データベースを VACUUM / ANALYZE で最適化します。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;"
                                           Style="{StaticResource IconText}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="DBを最適化"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="クリーンアップ" Style="{StaticResource SettingsFieldLabel}" />
                        <Button Command="{Binding OpenCleanupToolCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                HorizontalAlignment="Left"
                                Padding="14,6"
                                ToolTip="KoeNote クリーンアップツールを開きます。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           Style="{StaticResource IconText}"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="クリーンアップツールを開く"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
