<UserControl x:Class="KoeNote.App.Controls.ReadableDocumentEditBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="32">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenReadableDocumentBlocks" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentBlocks}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenReadableDocumentDirty" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReadableDocumentUnsavedEdits}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableEditPillButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Yu Gothic UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#D6DAE1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF2F6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ReadableEditSaveButton" TargetType="Button" BasedOn="{StaticResource ReadableEditPillButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style x:Key="ReadableEditGhostButton" TargetType="Button" BasedOn="{StaticResource ReadableEditPillButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style x:Key="ReadableEditIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource VisibleWhenReadableDocumentBlocks}">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
            <Button Command="{Binding BeginReadableDocumentEditCommand}"
                    ToolTip="整文本文を編集">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ReadableEditPillButton}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadableDocumentEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE70F;" Style="{StaticResource ReadableEditIcon}" />
                    <TextBlock Text="編集" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Border Background="#FFF7ED"
                    BorderBrush="#FED7AA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Height="28"
                    Padding="9,0"
                    Margin="0,0,8,0"
                    Style="{StaticResource VisibleWhenReadableDocumentDirty}">
                <TextBlock Text="未保存"
                           Foreground="#B45309"
                           FontFamily="Yu Gothic UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Border>

            <Button Command="{Binding SaveReadableDocumentEditCommand}"
                    ToolTip="編集内容を保存">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ReadableEditSaveButton}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadableDocumentEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" Style="{StaticResource ReadableEditIcon}" Foreground="#FFFFFF" />
                    <TextBlock Text="保存" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Command="{Binding DiscardReadableDocumentEditCommand}"
                    Margin="6,0,0,0"
                    ToolTip="編集を破棄">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ReadableEditGhostButton}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsReadableDocumentEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE711;" Style="{StaticResource ReadableEditIcon}" />
                    <TextBlock Text="破棄" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
