<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <UserControl.Resources>
        <Style x:Key="TranscriptToggleTrack" TargetType="Border">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="17" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#CBD5E1" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TranscriptToggleThumb" TargetType="Ellipse">
            <Setter Property="Width" Value="13" />
            <Setter Property="Height" Value="13" />
            <Setter Property="Fill" Value="#FFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="Margin" Value="0,0,2,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TranscriptInlineToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SpeakerChipComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="13"
                                                Padding="10,0,8,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="8"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="5,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="#E5E7EB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  Padding="4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillSearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranscriptTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#9CA3AF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid ClipToBounds="False" SnapsToDevicePixels="False">
                            <Border x:Name="HoverPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <Border x:Name="SelectedPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Margin="{TemplateBinding Padding}" />
                            <Border x:Name="AccentLine"
                                    Height="2"
                                    Background="Transparent"
                                    CornerRadius="1"
                                    VerticalAlignment="Bottom"
                                    Margin="10,0,10,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverPlate" Property="Background" Value="#F8FAFC" />
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectedPlate" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="AccentLine" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TranscriptCardTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel KeyboardNavigation.TabNavigation="Local">
                            <Border DockPanel.Dock="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1">
                                <Grid Height="42" Margin="16,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文字起こし"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0" />
                                    <TabPanel Grid.Column="1"
                                              x:Name="HeaderPanel"
                                              IsItemsHost="True"
                                              KeyboardNavigation.TabIndex="1"
                                              VerticalAlignment="Center"
                                              Background="Transparent" />
                                </Grid>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,6">
                                <Grid MinHeight="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="話者:"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource SpeakerChipComboBox}"
                                              ItemsSource="{Binding SpeakerFilters}"
                                              SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}"
                                              MinWidth="70"
                                              Margin="0,0,8,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Left" />
                                    <Grid Grid.Column="2"
                                          Width="200"
                                          Height="28"
                                          HorizontalAlignment="Left">
                                        <TextBox x:Name="SegmentSearchTextBox"
                                                 Style="{StaticResource PillSearchTextBox}"
                                                 Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="28"
                                                 Padding="30,0,32,0"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="発話内容を検索" />
                                        <TextBlock Text="&#xE721;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   Margin="12,0,0,0"
                                                   IsHitTestVisible="False" />
                                        <TextBlock Text="テキストを検索"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   Margin="32,0,0,0"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="" />
                                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SegmentSearchTextBox}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="x"
                                                Command="{Binding ClearSegmentSearchCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SearchClearButton}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    <ToggleButton Grid.Column="3"
                                                  Style="{StaticResource TranscriptInlineToggle}"
                                                  IsChecked="{Binding IsTranscriptAutoScrollEnabled, Mode=TwoWay}"
                                                  ToolTip="再生位置に合わせてセグメントへ自動スクロール">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="自動スクロール"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Grid>
                                                <Border Style="{StaticResource TranscriptToggleTrack}" />
                                                <Ellipse Style="{StaticResource TranscriptToggleThumb}" />
                                            </Grid>
                                        </StackPanel>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              KeyboardNavigation.TabIndex="2"
                                              KeyboardNavigation.TabNavigation="Local" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource PanelBorder}" Padding="0">
        <DockPanel>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding ExportWarning}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="16,8,16,0" />

            <TabControl Style="{StaticResource TranscriptCardTabControl}"
                        ItemContainerStyle="{StaticResource TranscriptTabItem}"
                        SelectedIndex="{Binding SelectedTranscriptTabIndex, Mode=TwoWay}">
                <TabItem Header="整文">
                    <controls:ReadablePolishedPanel />
                </TabItem>
                <TabItem Header="素起こし">
                    <controls:TranscriptSegmentList DisplayMode="Raw" />
                </TabItem>
                <TabItem Header="差分">
                    <controls:TranscriptSegmentList DisplayMode="Diff" />
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Grid MinWidth="92">
                            <Border x:Name="PolishedTabPulse"
                                    Background="#FEF3C7"
                                    BorderBrush="#FBBF24"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="4,-4,4,-4"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPolishedTranscriptTabHighlighted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0"
                                                                             To="0.82"
                                                                             Duration="0:0:0.45"
                                                                             AutoReverse="True"
                                                                             RepeatBehavior="3x" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="レビュー候補"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextTrimming="None" />
                        </Grid>
                    </TabItem.Header>
                    <controls:TranscriptSegmentList DisplayMode="Polished" />
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
