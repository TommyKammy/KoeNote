<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="文字起こし" Style="{StaticResource SectionTitle}" />
                        <CheckBox Grid.Column="1" Content="自動スクロール" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,10" Foreground="{StaticResource MutedBrush}" />
                        <TextBox Grid.Column="2" Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}" MinHeight="34" Padding="10,7" ToolTip="発話内容を検索" Margin="0,0,0,10" />
                        <ComboBox Grid.Column="3" ItemsSource="{Binding SpeakerFilters}" SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}" Margin="8,0,0,10" MinHeight="34" />
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,10">
                            <Button Style="{StaticResource OutlineNeutralButton}" Padding="11,8" Command="{Binding ExportSelectedJobCommand}" ToolTip="TXT / Markdown / JSON / SRT / VTT export">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                                    <TextBlock Text="Export" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Padding="10,8" MinWidth="0" Margin="6,0,0,0" Command="{Binding OpenExportFolderCommand}" ToolTip="Open export folder">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="5" Text="{Binding ExportWarning}" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>

                    <Border DockPanel.Dock="Bottom" Background="#FAFBFC" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Button Padding="7,6" MinWidth="0" ToolTip="前へ">
                                    <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" />
                                </Button>
                                <Button Padding="10,7" MinWidth="0" Margin="3,0" Background="{StaticResource AccentLightBrush}" Command="{Binding PlayPauseAudioCommand}" ToolTip="{Binding SelectedJobPlaybackPath}">
                                    <TextBlock Text="{Binding PlayPauseAudioIcon}" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" />
                                </Button>
                                <Button Padding="7,6" MinWidth="0" ToolTip="次へ">
                                    <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" />
                                </Button>
                                <ComboBox Width="66" MinHeight="30" Margin="6,0,0,0" ItemsSource="{Binding PlaybackRates}" SelectedItem="{Binding PlaybackRate, Mode=TwoWay}" ItemStringFormat="{}{0:0.##}x" />
                            </StackPanel>

                            <Grid Grid.Column="1" VerticalAlignment="Center" MinWidth="180">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <UniformGrid Rows="1" Columns="28" Height="30" VerticalAlignment="Center" Margin="0,0,0,2">
                                    <Border Width="4" Height="10" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="18" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="14" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="24" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="16" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="28" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="12" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="22" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="9" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="20" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="26" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="15" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="23" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="12" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="29" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="18" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="11" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="21" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="14" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="25" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="17" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="10" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="23" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="13" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="27" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="16" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="12" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                    <Border Width="4" Height="20" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                </UniformGrid>
                                <Slider Grid.Row="1" Minimum="0" Maximum="{Binding PlaybackDurationSeconds}" Value="{Binding PlaybackPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsMoveToPointEnabled="True" />
                            </Grid>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock Text="{Binding PlaybackTimeDisplay}" Style="{StaticResource MutedText}" VerticalAlignment="Center" FontSize="11" />
                                <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedBrush}" FontSize="15" VerticalAlignment="Center" Margin="9,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="選択セグメントを手修正" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding SelectedSegmentEditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         MinHeight="44"
                                         Margin="0,5,0,0"
                                         ToolTip="元の文字起こしは残ります。出力には、ここで保存した文章が使われます。" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="話者名" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding SelectedSpeakerAlias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="34"
                                         Margin="0,5,0,0"
                                         ToolTip="同じ話者 ID の表示名として保存します。" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                                <Button Style="{StaticResource OutlineNeutralButton}" Padding="12,9" Command="{Binding SaveSegmentEditCommand}" ToolTip="本文を final_text として保存">
                                    <TextBlock Text="本文保存" FontWeight="SemiBold" />
                                </Button>
                                <Button Style="{StaticResource OutlineNeutralButton}" Padding="12,9" Command="{Binding SaveSpeakerAliasCommand}" Margin="6,0,0,0" ToolTip="話者表示名を保存">
                                    <TextBlock Text="話者保存" FontWeight="SemiBold" />
                                </Button>
                                <Button Padding="10,9" Command="{Binding UndoLastOperationCommand}" Margin="6,0,0,0" ToolTip="直前のレビュー/編集/話者変更を取り消す">
                                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" />
                                </Button>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Text="元の文字起こしは残ります。出力には、ここで保存した文章が使われます。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       Margin="0,8,0,0" />
                        </Grid>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#FAFBFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="12,8" Margin="0,0,0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="時間" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="話者" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="発話内容" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="SegmentList"
                             ItemsSource="{Binding FilteredSegments}"
                             SelectedItem="{Binding SelectedSegment, Mode=TwoWay}"
                             Style="{StaticResource CardListBox}"
                             ItemContainerStyle="{StaticResource SegmentListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,11" Background="Transparent" BorderBrush="#EEF1F3" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Start}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Top" />
                                        <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="12" Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Speaker}" FontSize="12" Foreground="#475569" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Text}" TextWrapping="Wrap" TextTrimming="None" FontSize="14" LineHeight="22" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
</UserControl>
