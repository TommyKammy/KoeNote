<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="文字起こし" Style="{StaticResource SectionTitle}" />
                        <CheckBox Content="自動スクロール" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,10" Foreground="{StaticResource MutedBrush}" />
                        <TextBox Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}" MinHeight="34" Padding="10,7" ToolTip="発話内容を検索" Margin="0,0,0,10" />
                        <ComboBox ItemsSource="{Binding SpeakerFilters}" SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}" Margin="8,0,0,10" MinHeight="34" />
                    </Grid>

                    <Border DockPanel.Dock="Bottom" Background="#FAFBFC" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Padding="9,7" MinWidth="0">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Button Padding="9,7" MinWidth="0" Margin="4,0,12,0">
                                <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" />
                            </Button>
                            <Grid VerticalAlignment="Center" Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="5" Height="14" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="24" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="18" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="30" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="20" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="28" Background="#2F8F5B" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="16" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="26" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="12" Background="#B7D8C4" CornerRadius="2" VerticalAlignment="Center" />
                                <Border Width="5" Height="22" Background="#7DB994" CornerRadius="2" VerticalAlignment="Center" />
                                <Slider VerticalAlignment="Bottom" Minimum="0" Maximum="100" Value="35" Margin="0,26,0,0" />
                            </Grid>
                            <TextBlock Text="00:03:21 / 00:10:00" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="14,0,0,0" />
                        </Grid>
                    </Border>

                    <ListBox ItemsSource="{Binding FilteredSegments}"
                             Style="{StaticResource CardListBox}"
                             ItemContainerStyle="{StaticResource SegmentListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,11" Background="Transparent" BorderBrush="#EEF1F3" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Start}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Top" />
                                        <Border Background="#F1F5F9" CornerRadius="12" Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Speaker}" FontSize="12" Foreground="#475569" />
                                        </Border>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextTrimming="None" FontSize="14" LineHeight="22" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
</UserControl>
