<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="TranscriptTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,7" />
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid ClipToBounds="False" SnapsToDevicePixels="False">
                            <Border x:Name="HoverPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <Border x:Name="SelectedPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Margin="{TemplateBinding Padding}" />
                            <Border x:Name="AccentLine"
                                    Height="2"
                                    Background="Transparent"
                                    CornerRadius="1"
                                    VerticalAlignment="Bottom"
                                    Margin="10,0,10,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverPlate" Property="Background" Value="#F8FAFC" />
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectedPlate" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="AccentLine" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource PanelBorder}" Padding="18">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MinHeight="38" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource LucideCardIconBadge}">
                        <Path Style="{StaticResource LucidePathIcon}"
                              Data="M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2M7 15h4M15 15h2M7 11h2M13 11h4" />
                    </Border>
                    <TextBlock Text="文字起こし"
                               Style="{StaticResource SectionTitle}"
                               Margin="0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <CheckBox Grid.Column="1"
                          Content="自動スクロール"
                          IsChecked="{Binding IsTranscriptAutoScrollEnabled, Mode=TwoWay}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,14,0"
                          Foreground="{StaticResource MutedBrush}" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Grid Width="220"
                          Height="38"
                          Margin="0,0,8,0">
                        <TextBox x:Name="SegmentSearchTextBox"
                                 Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="38"
                                 Padding="10,0,34,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="発話内容を検索" />
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="" />
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SegmentSearchTextBox}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="x"
                                Command="{Binding ClearSegmentSearchCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SearchClearButton}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <ComboBox Style="{StaticResource ToolbarComboBox}"
                              ItemsSource="{Binding SpeakerFilters}"
                              SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}"
                              Width="150"
                              Height="38"
                              HorizontalAlignment="Right"
                              HorizontalContentAlignment="Left" />
                </StackPanel>
            </Grid>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding ExportWarning}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />

            <TabControl Style="{StaticResource CardTabControl}"
                        ItemContainerStyle="{StaticResource TranscriptTabItem}"
                        SelectedIndex="{Binding SelectedTranscriptTabIndex, Mode=TwoWay}">
                <TabItem Header="素起こし">
                    <controls:TranscriptSegmentList DisplayMode="Raw" />
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Grid MinWidth="72">
                            <Border x:Name="PolishedTabPulse"
                                    Background="#FEF3C7"
                                    BorderBrush="#FBBF24"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="4,-4,4,-4"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPolishedTranscriptTabHighlighted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0"
                                                                             To="0.82"
                                                                             Duration="0:0:0.45"
                                                                             AutoReverse="True"
                                                                             RepeatBehavior="3x" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="整文"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextTrimming="None" />
                        </Grid>
                    </TabItem.Header>
                    <controls:TranscriptSegmentList DisplayMode="Polished" />
                </TabItem>
                <TabItem Header="差分">
                    <controls:TranscriptSegmentList DisplayMode="Diff" />
                </TabItem>
                <TabItem Header="読みやすく整文">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,9"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource OutlineSuccessButton}"
                                        Command="{Binding RunReadablePolishingCommand}"
                                        ToolTip="{Binding ReadablePolishedActionToolTip}"
                                        Padding="14,8"
                                        Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="&#xE70F;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13"
                                                   Margin="0,0,7,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ReadablePolishedActionText}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Ellipse DockPanel.Dock="Left"
                                         Width="8"
                                         Height="8"
                                         Fill="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ReadablePolishedStatus}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </DockPanel>
                                <ProgressBar Grid.Row="1"
                                             Height="4"
                                             Margin="0,8,0,0"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsReadablePolishingInProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding ReadablePolishedContentDisplay}"
                                           FontSize="14"
                                           FontWeight="Normal"
                                           LineHeight="23"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
