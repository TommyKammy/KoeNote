<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <UserControl.Resources>
        <Style x:Key="TranscriptToggleTrack" TargetType="Border">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="17" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#CBD5E1" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TranscriptToggleThumb" TargetType="Ellipse">
            <Setter Property="Width" Value="13" />
            <Setter Property="Height" Value="13" />
            <Setter Property="Fill" Value="#FFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Right" />
                    <Setter Property="Margin" Value="0,0,2,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TranscriptInlineToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TranscriptZoomButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>
        <Style x:Key="TranscriptZoomTextButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>
        <Style x:Key="TranscriptZoomIconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SpeakerChipComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Tag="{Binding SelectionBoxItem, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SpeakerChipBrushConverter}}"
                                                BorderBrush="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SpeakerChipBrushConverter}, ConverterParameter=Border}"
                                                BorderThickness="1"
                                                CornerRadius="13"
                                                Padding="10,0,8,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                           Foreground="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SpeakerChipBrushConverter}, ConverterParameter=Foreground}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="8"
                                                           Foreground="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SpeakerChipBrushConverter}, ConverterParameter=Foreground}"
                                                           VerticalAlignment="Center"
                                                           Margin="5,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#FFFFFF"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  Padding="4"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranscriptTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#9CA3AF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid ClipToBounds="False" SnapsToDevicePixels="False">
                            <Border x:Name="HoverPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <Border x:Name="SelectedPlate"
                                    Background="Transparent"
                                    CornerRadius="6,6,0,0"
                                    Margin="2,0,2,1" />
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Margin="{TemplateBinding Padding}" />
                            <Border x:Name="AccentLine"
                                    Height="2"
                                    Background="Transparent"
                                    CornerRadius="1"
                                    VerticalAlignment="Bottom"
                                    Margin="10,0,10,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverPlate" Property="Background" Value="#F8FAFC" />
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectedPlate" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="AccentLine" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TranscriptTabHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TranscriptCardTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel KeyboardNavigation.TabNavigation="Local">
                            <Border DockPanel.Dock="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1">
                                <Grid Height="42" Margin="16,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文字起こし"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0" />
                                    <TabPanel Grid.Column="1"
                                              x:Name="HeaderPanel"
                                              IsItemsHost="True"
                                              KeyboardNavigation.TabIndex="1"
                                              VerticalAlignment="Center"
                                              Background="Transparent" />
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Margin="10,0,0,0">
                                        <Button Style="{StaticResource TranscriptZoomButton}"
                                                Command="{Binding ZoomOutCommand}"
                                                ToolTip="{Binding MainContentZoomToolTip}">
                                            <TextBlock Text="&#xE71F;" Style="{StaticResource TranscriptZoomIconText}" />
                                        </Button>
                                        <Button Style="{StaticResource TranscriptZoomTextButton}"
                                                Command="{Binding ResetZoomCommand}"
                                                ToolTip="本文フォントサイズを100%に戻す">
                                            <TextBlock Text="{Binding MainContentZoomPercentText}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                        <Button Style="{StaticResource TranscriptZoomButton}"
                                                Command="{Binding ZoomInCommand}"
                                                ToolTip="{Binding MainContentZoomToolTip}">
                                            <TextBlock Text="&#xE8A3;" Style="{StaticResource TranscriptZoomIconText}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border DockPanel.Dock="Top"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,0,0,1"
                                    Padding="14,6">
                                <Grid MinHeight="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="話者:"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource SpeakerChipComboBox}"
                                              ItemsSource="{Binding SpeakerFilters}"
                                              SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}"
                                              MinWidth="70"
                                              Margin="0,0,8,0"
                                              HorizontalAlignment="Left"
                                              HorizontalContentAlignment="Left">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Converter={StaticResource SpeakerChipBrushConverter}}"
                                                        BorderBrush="{Binding Converter={StaticResource SpeakerChipBrushConverter}, ConverterParameter=Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="9,4"
                                                        Margin="0,1">
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{Binding Converter={StaticResource SpeakerChipBrushConverter}, ConverterParameter=Foreground}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Grid Grid.Column="2"
                                          Width="200"
                                          Height="28"
                                          HorizontalAlignment="Left"
                                          Background="Transparent"
                                          PreviewMouseLeftButtonDown="OnSegmentSearchBoxPreviewMouseLeftButtonDown">
                                        <Border Background="#FFFFFF"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="14" />
                                        <TextBox x:Name="SegmentSearchTextBox"
                                                 Style="{StaticResource SearchPillTextBox}"
                                                 Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 GotKeyboardFocus="OnSegmentSearchBoxGotKeyboardFocus"
                                                 PreviewMouseLeftButtonDown="OnSegmentSearchTextBoxPreviewMouseLeftButtonDown"
                                                 ToolTip="発話内容を検索" />
                                        <Grid Width="14"
                                              Height="14"
                                              Margin="12,0,0,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False">
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Stroke="#2563EB"
                                                     StrokeThickness="1.7"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Top"
                                                     Margin="1.5,1.5,0,0" />
                                            <Path Data="M8.6 8.6 L12.5 12.5"
                                                  Stroke="{StaticResource MutedBrush}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Grid>
                                        <TextBlock Text="テキストを検索"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   Margin="36,0,0,0"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="" />
                                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SegmentSearchTextBox}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="x"
                                                Command="{Binding ClearSegmentSearchCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SearchClearButton}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SegmentSearchTextBox}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    <ToggleButton Grid.Column="3"
                                                  IsChecked="{Binding IsTranscriptAutoScrollEnabled, Mode=TwoWay}"
                                                  ToolTip="再生位置に合わせてセグメントへ自動スクロール">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton" BasedOn="{StaticResource TranscriptInlineToggle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTranscriptTabIndex}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="自動スクロール"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Grid>
                                                <Border Style="{StaticResource TranscriptToggleTrack}" />
                                                <Ellipse Style="{StaticResource TranscriptToggleThumb}" />
                                            </Grid>
                                        </StackPanel>
                                    </ToggleButton>

                                    <Button Grid.Column="4"
                                            Command="{Binding RunReadablePolishingCommand}"
                                            ToolTip="{Binding ReadablePolishedActionToolTip}"
                                            VerticalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource OutlineSuccessButton}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Height" Value="26" />
                                                <Setter Property="Padding" Value="10,4" />
                                                <Setter Property="Margin" Value="10,0,0,0" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#22C55E" ShadowDepth="0" BlurRadius="0" Opacity="0" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTranscriptTabIndex}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsReadablePolishingInProgress}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="PolishGlowSB">
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                                     From="4" To="16"
                                                                                     Duration="0:0:0.85" />
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                                     From="0.55" To="1.0"
                                                                                     Duration="0:0:0.85" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="PolishGlowSB" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ReadablePolishedActionText}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              KeyboardNavigation.TabIndex="2"
                                              KeyboardNavigation.TabNavigation="Local" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource PanelBorder}" Padding="0">
        <DockPanel>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding ExportWarning}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="16,8,16,0" />

            <TabControl Style="{StaticResource TranscriptCardTabControl}"
                        ItemContainerStyle="{StaticResource TranscriptTabItem}"
                        SelectedIndex="{Binding SelectedTranscriptTabIndex, Mode=TwoWay}">
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="整文" Style="{StaticResource TranscriptTabHeaderText}" />
                    </TabItem.Header>
                    <controls:ReadablePolishedPanel />
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="素起こし" Style="{StaticResource TranscriptTabHeaderText}" />
                    </TabItem.Header>
                    <controls:TranscriptSegmentList DisplayMode="Raw" />
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="差分" Style="{StaticResource TranscriptTabHeaderText}" />
                    </TabItem.Header>
                    <controls:TranscriptSegmentList DisplayMode="Diff" />
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Grid MinWidth="92">
                            <Border x:Name="PolishedTabPulse"
                                    Background="#FEF3C7"
                                    BorderBrush="#FBBF24"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="4,-4,4,-4"
                                    Opacity="0"
                                    IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPolishedTranscriptTabHighlighted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0"
                                                                             To="0.82"
                                                                             Duration="0:0:0.45"
                                                                             AutoReverse="True"
                                                                             RepeatBehavior="3x" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <TextBlock Text="レビュー候補"
                                       Style="{StaticResource TranscriptTabHeaderText}"
                                       HorizontalAlignment="Center"
                                       TextTrimming="None" />
                        </Grid>
                    </TabItem.Header>
                    <controls:TranscriptSegmentList DisplayMode="Polished" />
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
