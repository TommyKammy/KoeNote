<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <Border Style="{StaticResource PanelBorder}" Padding="16">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="文字起こし" Style="{StaticResource SectionTitle}" />
                <CheckBox Grid.Column="1"
                          Content="自動スクロール"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,14,10"
                          Foreground="{StaticResource MutedBrush}" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,10">
                    <TextBox Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="180"
                             MaxWidth="180"
                             MinHeight="34"
                             HorizontalAlignment="Right"
                             Padding="10,7"
                             ToolTip="発話内容を検索" />
                    <ComboBox ItemsSource="{Binding SpeakerFilters}"
                              SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}"
                              Width="120"
                              MinWidth="120"
                              MaxWidth="120"
                              Height="34"
                              HorizontalAlignment="Right"
                              HorizontalContentAlignment="Left"
                              Margin="8,0,0,0" />
                    <Button Style="{StaticResource OutlineNeutralButton}"
                            Width="80"
                            Height="34"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Margin="8,0,0,0"
                            Command="{Binding ExportSelectedJobCommand}"
                            ToolTip="TXT / Markdown / JSON / SRT / VTT を出力">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" />
                            <TextBlock Text="出力" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Padding="10,8"
                            MinWidth="0"
                            Margin="6,0,0,0"
                            Command="{Binding OpenExportFolderCommand}"
                            ToolTip="出力フォルダを開く">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Text="{Binding ExportWarning}"
                           Foreground="{StaticResource WarningBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </Grid>

            <controls:TranscriptAudioPlayer DockPanel.Dock="Bottom" />
            <controls:TranscriptEditPanel DockPanel.Dock="Bottom" />
            <controls:TranscriptSegmentList />
        </DockPanel>
    </Border>
</UserControl>
