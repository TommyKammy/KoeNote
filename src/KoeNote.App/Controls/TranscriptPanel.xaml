<UserControl x:Class="KoeNote.App.Controls.TranscriptPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <Border Style="{StaticResource PanelBorder}" Padding="18">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MinHeight="38" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="文字起こし"
                           Style="{StaticResource SectionTitle}"
                           Margin="0"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Column="1"
                          Content="自動スクロール"
                          IsChecked="{Binding IsTranscriptAutoScrollEnabled, Mode=TwoWay}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,14,0"
                          Foreground="{StaticResource MutedBrush}" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Grid Width="220"
                          Height="38"
                          Margin="0,0,8,0">
                        <TextBox Text="{Binding SegmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="38"
                                 Padding="34,8,12,8"
                                 ToolTip="発話内容を検索" />
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False" />
                    </Grid>
                    <ComboBox Style="{StaticResource ToolbarComboBox}"
                              ItemsSource="{Binding SpeakerFilters}"
                              SelectedItem="{Binding SelectedSpeakerFilter, Mode=TwoWay}"
                              Width="150"
                              Height="38"
                              HorizontalAlignment="Right"
                              HorizontalContentAlignment="Left"
                              Margin="0,0,8,0" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Width="88"
                            Height="38"
                            Padding="0"
                            HorizontalAlignment="Right"
                            Command="{Binding ExportSelectedJobCommand}"
                            ToolTip="TXT / Markdown / JSON / SRT / VTT を出力">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0" />
                            <TextBlock Text="出力" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Width="38"
                            Height="38"
                            Padding="0"
                            MinWidth="0"
                            Margin="6,0,0,0"
                            Command="{Binding OpenExportFolderCommand}"
                            ToolTip="出力フォルダを開く">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding ExportWarning}"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <controls:TranscriptSegmentList />
        </DockPanel>
    </Border>
</UserControl>
