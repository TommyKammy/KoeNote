<UserControl x:Class="KoeNote.App.Controls.TranscriptEditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Expander Margin="0,10,0,0"
              IsExpanded="False"
              Style="{StaticResource CompactEditExpander}">
        <Expander.Header>
            <Grid Height="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="選択セグメント"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedSegment.Text}"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="編集"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </Grid>
        </Expander.Header>

        <Border Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="選択セグメントを手修正" Style="{StaticResource MutedText}" />
                <TextBox Text="{Binding SelectedSegmentEditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         MinHeight="46"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         Margin="0,7,0,0"
                         ToolTip="元の文字起こしは残ります。出力には、ここで保存した文章が使われます。" />
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="話者名" Style="{StaticResource MutedText}" />
                <TextBox Text="{Binding SelectedSpeakerAlias, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="42"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         Margin="0,7,0,0"
                         ToolTip="同じ話者IDの表示名として保存します。" />
            </StackPanel>

            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,18,0,0">
                <Button Style="{StaticResource OutlineNeutralButton}" MinHeight="42" Padding="12,0" Command="{Binding SaveSegmentEditCommand}" ToolTip="本文を final_text として保存">
                    <TextBlock Text="本文保存" FontWeight="SemiBold" />
                </Button>
                <Button Style="{StaticResource OutlineNeutralButton}" MinHeight="42" Padding="12,0" Command="{Binding SaveSpeakerAliasCommand}" Margin="6,0,0,0" ToolTip="話者表示名を保存">
                    <TextBlock Text="話者保存" FontWeight="SemiBold" />
                </Button>
                <Button Width="42" MinHeight="42" Padding="0" Command="{Binding UndoLastOperationCommand}" Margin="6,0,0,0" ToolTip="直前のレビュー/編集/話者変更を取り消す">
                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" />
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="5"
                       Text="元の文字起こしは残ります。出力には、ここで保存した文章が使われます。"
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="11"
                       Margin="0,8,0,0" />
            </Grid>
        </Border>
    </Expander>
</UserControl>
