<UserControl x:Class="KoeNote.App.Controls.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls"
             x:Name="Root">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Log / Settings / Setup / Models" Style="{StaticResource SectionTitle}" />
                        <TextBlock Grid.Column="1" Text="{Binding LatestLog}" Style="{StaticResource MutedText}" TextAlignment="Right" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Margin="12,0,0,0" Padding="10,6" Command="{Binding OpenSelectedDetailPanelCommand}" ToolTip="Open selected tab in a wide side panel">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE740;" Style="{StaticResource IconText}" />
                                <TextBlock Text="Wide" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TabControl BorderThickness="0" Background="Transparent" SelectedIndex="{Binding SelectedLogPanelTabIndex, Mode=TwoWay}">
                        <TabItem Header="Logs">
                            <controls:LogEntriesTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="Settings">
                            <controls:SettingsTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="Setup">
                            <controls:SetupWizardTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="Models">
                            <controls:ModelCatalogTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
</UserControl>
