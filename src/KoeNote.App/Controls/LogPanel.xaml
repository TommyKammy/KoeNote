<UserControl x:Class="KoeNote.App.Controls.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls"
             x:Name="Root">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ログ / 設定 / セットアップ / モデル" Style="{StaticResource SectionTitle}" />
                        <TextBlock Grid.Column="1" Text="{Binding LatestLog}" Style="{StaticResource MutedText}" TextAlignment="Right" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="範囲" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Width="150"
                                      ItemsSource="{Binding DiagnosticLogScopes}"
                                      SelectedItem="{Binding SelectedDiagnosticLogScope, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="3" Margin="8,0,0,0" Padding="10,6" Command="{Binding OpenLogFolderCommand}" ToolTip="ローカルログフォルダを開きます">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                                <TextBlock Text="フォルダ" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4" Margin="8,0,0,0" Padding="10,6" Command="{Binding ExportLogsCommand}" ToolTip="診断パッケージを出力します">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" />
                                <TextBlock Text="ログ出力" FontSize="12" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="5" Margin="8,0,0,0" Padding="10,6" Command="{Binding OpenSelectedDetailPanelCommand}" ToolTip="選択中のタブを広いパネルで開きます">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE740;" Style="{StaticResource IconText}" />
                                <TextBlock Text="拡大" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TabControl Style="{StaticResource CardTabControl}" SelectedIndex="{Binding SelectedLogPanelTabIndex, Mode=TwoWay}">
                        <TabItem Header="設定">
                            <controls:SettingsTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="辞書プリセット">
                            <controls:DomainPresetTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="モデル">
                            <controls:ModelCatalogTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="セットアップ">
                            <controls:SetupWizardTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                        <TabItem Header="ログ">
                            <controls:LogEntriesTab DataContext="{Binding DataContext, ElementName=Root}" />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
</UserControl>
