<UserControl x:Class="KoeNote.App.Controls.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Log / Models / Setup" Style="{StaticResource SectionTitle}" />
                        <TextBlock Grid.Column="1" Text="{Binding LatestLog}" Style="{StaticResource MutedText}" TextAlignment="Right" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Margin="12,0,0,0" Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" />
                                <TextBlock Text="Save" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TabControl BorderThickness="0" Background="Transparent">
                        <TabItem Header="Logs">
                            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent" FontFamily="Consolas">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="62" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding CreatedAtDisplay}" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="12" />
                                            <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" FontSize="12" />
                                            <TextBlock Grid.Column="2" Text="{Binding Stage}" Foreground="#64748B" FontFamily="Consolas" FontSize="12" />
                                            <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#334155" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="Models">
                            <DockPanel Margin="0,8,0,0">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Command="{Binding RegisterPreinstalledModelsCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Scan" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding UseSelectedModelCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Use" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding ShowSelectedModelLicenseCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="License" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding ForgetSelectedModelCommand}" Padding="10,5">
                                        <TextBlock Text="Forget" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding ModelCatalogEntries}"
                                         SelectedItem="{Binding SelectedModelCatalogEntry, Mode=TwoWay}"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="94" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Role}" Foreground="#64748B" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="#334155" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding SizeSummary}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="{Binding RuntimeRequirement}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4" Text="{Binding LicenseName}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="5" Text="{Binding InstallState}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextAlignment="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="Setup">
                            <DockPanel Margin="0,8,0,0">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Command="{Binding SetupBackCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Back" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupNextCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Next" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupUseRecommendedCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Recommended" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupAcceptLicensesCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Accept license" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupDownloadAsrCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Download ASR" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupDownloadReviewCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Download LLM" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupRunSmokeCommand}" Padding="10,5" Margin="0,0,8,0">
                                        <TextBlock Text="Smoke" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding SetupCompleteCommand}" Padding="10,5">
                                        <TextBlock Text="Complete" FontSize="12" />
                                    </Button>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ListBox ItemsSource="{Binding SetupSteps}" BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,8,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="58" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" Foreground="#334155" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding SetupStatusSummary}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="ASR" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding SetupAsrModelChoices}"
                                                      SelectedItem="{Binding SelectedSetupAsrModel, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName"
                                                      MinWidth="260" />
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Review LLM" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding SetupReviewModelChoices}"
                                                      SelectedItem="{Binding SelectedSetupReviewModel, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName"
                                                      MinWidth="260" />
                                        </Grid>
                                        <TextBlock Text="{Binding SetupStorageRoot}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="86" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Local path" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding SetupLocalModelPath, UpdateSourceTrigger=PropertyChanged}" MinWidth="220" />
                                            <Button Grid.Column="2" Command="{Binding SetupRegisterLocalAsrCommand}" Padding="8,4" Margin="8,0,0,0">
                                                <TextBlock Text="ASR local" FontSize="12" />
                                            </Button>
                                            <Button Grid.Column="3" Command="{Binding SetupRegisterLocalReviewCommand}" Padding="8,4" Margin="8,0,0,0">
                                                <TextBlock Text="LLM local" FontSize="12" />
                                            </Button>
                                        </Grid>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="96" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Offline pack" Foreground="#64748B" FontSize="12" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding SetupOfflineModelPackPath, UpdateSourceTrigger=PropertyChanged}" MinWidth="220" />
                                            <Button Grid.Column="2" Command="{Binding SetupImportOfflinePackCommand}" Padding="8,4" Margin="8,0,0,0">
                                                <TextBlock Text="Import pack" FontSize="12" />
                                            </Button>
                                        </Grid>
                                        <ListBox ItemsSource="{Binding SetupModelAudits}" BorderThickness="0" Background="Transparent" MaxHeight="76" Margin="0,0,0,8">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="110" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ModelId}" Foreground="#334155" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ChecksumDetail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding ManifestDetail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="3" Text="{Binding LicenseDetail}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <ListBox ItemsSource="{Binding SetupSmokeChecks}" BorderThickness="0" Background="Transparent" MaxHeight="116">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="54" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="#334155" FontSize="12" />
                                                        <TextBlock Grid.Column="1" Text="{Binding IsOk}" Foreground="{StaticResource AccentBrush}" FontSize="12" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
</UserControl>
