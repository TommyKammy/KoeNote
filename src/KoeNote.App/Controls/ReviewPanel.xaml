<UserControl x:Class="KoeNote.App.Controls.ReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="推敲レビュー" Style="{StaticResource SectionTitle}" />
                            <Border Background="#FFF7ED" CornerRadius="12" Padding="9,4" VerticalAlignment="Top">
                                <TextBlock Text="{Binding Confidence, StringFormat=信頼度 {0:P0}}" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Border Background="#FEF3C7" CornerRadius="12" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,14">
                            <TextBlock Text="{Binding ReviewIssueType}" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="SemiBold" />
                        </Border>

                        <TextBlock Text="原文" Style="{StaticResource MutedText}" />
                        <TextBox Text="{Binding OriginalText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="82" Margin="0,5,0,14" Background="#FAFBFC" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                            <TextBlock Text="提案文" Style="{StaticResource MutedText}" />
                            <Border Background="{StaticResource AccentLightBrush}" CornerRadius="10" Padding="8,3" Margin="8,-2,0,0">
                                <TextBlock Text="API連携" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <TextBox Text="{Binding SuggestedText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" MinHeight="82" Margin="0,0,0,14" Background="#F7FCF9" BorderBrush="#B7D8C4" />

                        <TextBlock Text="理由" Style="{StaticResource MutedText}" />
                        <TextBlock Text="{Binding ReviewReason}" TextWrapping="Wrap" TextTrimming="None" LineHeight="21" Margin="0,5,0,18" />

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Style="{StaticResource OutlineSuccessButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="採用" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource OutlineDangerButton}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" Foreground="{StaticResource DangerBrush}" />
                                    <TextBlock Text="却下" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Background="#FAFBFC" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="ASRコンテキスト" Style="{StaticResource SectionTitle}" FontSize="14" Margin="0,0,0,10" />
                                <TextBlock Text="Context" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding AsrContextText, UpdateSourceTrigger=PropertyChanged}" MinHeight="62" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,12" />
                                <TextBlock Text="Hotwords" Style="{StaticResource MutedText}" />
                                <TextBox Text="{Binding AsrHotwordsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" TextWrapping="Wrap" AcceptsReturn="True" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
</UserControl>