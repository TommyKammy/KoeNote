<UserControl x:Class="KoeNote.App.Controls.ReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:KoeNote.App.Models">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenSummaryStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSummaryContent}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoSummaryStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSummaryContent}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenSummaryRunningStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSummaryStageRunning}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenReviewOperationStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReviewOperationInProgress}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReviewApplyButton" TargetType="Button" BasedOn="{StaticResource OutlineSuccessButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ReviewSecondaryButton" TargetType="Button" BasedOn="{StaticResource OutlineNeutralButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ReviewSubheading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Padding="14,12,14,10"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="&#x2728;"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="15"
                                       Foreground="#F59E0B"
                                       VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Text="整文候補"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="13"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding SummaryStatus}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Style="{StaticResource VisibleWhenDraftStyle}">
                        <Button Padding="7,4"
                                MinWidth="0"
                                Command="{Binding SelectPreviousDraftCommand}"
                                ToolTip="前の候補">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                        <TextBlock Text="{Binding DraftPositionText}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="7,0" />
                        <Button Padding="7,4"
                                MinWidth="0"
                                Command="{Binding SelectNextDraftCommand}"
                                ToolTip="次の候補">
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="28"
                            Height="28"
                            Padding="0"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Command="{Binding CloseDetailPanelCommand}"
                            ToolTip="閉じる">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Button>
                </Grid>
            </Border>

            <Grid Margin="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" MinHeight="160" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="2*" MinHeight="140" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="2"
                          Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource LucideInlineIconBadge}"
                                            Background="{StaticResource AccentLightBrush}"
                                            CornerRadius="4">
                                        <Path Style="{StaticResource LucidePathIcon}"
                                              Width="14"
                                              Height="14"
                                              Stroke="{StaticResource AccentBrush}"
                                              Data="M10 5h11M10 12h11M10 19h11M3 10l3-3-3-3M3 20l3-3-3-3" />
                                    </Border>
                                    <TextBlock Text="要約"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="本文が更新されています"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummaryStale}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="生成中"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               Style="{StaticResource VisibleWhenSummaryRunningStyle}" />
                                    <Button Command="{Binding RunPostSummaryCommand}"
                                            ToolTip="{Binding SummaryActionToolTip}"
                                            MinWidth="90"
                                            Height="28"
                                            Padding="10,4"
                                            Style="{StaticResource OutlineSuccessButton}">
                                        <TextBlock Text="{Binding SummaryActionText}"
                                                   Foreground="#FFFFFF"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Background="#FAFBFC"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,14"
                                    Style="{StaticResource VisibleWhenNoSummaryStyle}">
                                <StackPanel>
                                    <TextBlock Text="要約はまだありません"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="「生成」を押すとAIが要約を作成します"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <TextBox Grid.Row="1"
                                 Text="{Binding SummaryContentDisplay, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="128"
                                 BorderThickness="0"
                                 Background="#FAFBFC"
                                 Padding="12"
                                 Style="{StaticResource VisibleWhenSummaryStyle}" />
                    </Grid>

                    <GridSplitter Grid.Row="1"
                                  Style="{StaticResource ModernHorizontalGridSplitter}" />

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Border Grid.Row="0"
                                        Style="{StaticResource VisibleWhenNoDraftStyle}"
                                        Background="#FAFBFC"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2728;"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="34"
                                                   Foreground="#F59E0B"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,10" />
                                        <TextBlock Text="整文候補はありません"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="「整文」タブで結果を確認し、&#x0A;承認すると候補がここに表示されます"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="0"
                                            Style="{StaticResource VisibleWhenDraftStyle}">
                                    <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="レビュー候補"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Border Background="#FFF7ED" CornerRadius="12" Padding="9,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Confidence, StringFormat=信頼度 {0:P0}}"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Background="#FEF3C7" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="{Binding ReviewIssueType}"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                            </WrapPanel>
                        </Grid>

                        <TextBlock Text="原文" Style="{StaticResource ReviewSubheading}" />
                        <TextBox Text="{Binding OriginalText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="74"
                                 Margin="0,5,0,14"
                                 Background="#FAFBFC"
                                 PreviewMouseLeftButtonUp="FocusDraftSegmentOnClick" />

                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="レビュー候補案" Style="{StaticResource ReviewSubheading}" />
                            <TextBlock Grid.Column="1"
                                       Text="ここで編集してから手修正できます"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBox Text="{Binding SuggestedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 MinHeight="82"
                                 Margin="0,0,0,14"
                                 Background="#F7FCF9"
                                 BorderBrush="#B7D8C4" />

                        <TextBlock Text="差分" Style="{StaticResource ReviewSubheading}" />
                        <Border Background="#FAFBFC"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,5,0,14"
                                PreviewMouseLeftButtonUp="FocusDraftSegmentOnClick">
                            <ItemsControl ItemsSource="{Binding DiffTokens}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="3,1" Margin="0,0,2,2" CornerRadius="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                            <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                            <Setter Property="Background" Value="{StaticResource DangerLightBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                            <Setter Property="Background" Value="#FFF7ED" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextTrimming="None" LineHeight="20">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock Text="理由" Style="{StaticResource ReviewSubheading}" />
                        <TextBlock Text="{Binding ReviewReason}"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   LineHeight="21"
                                   Margin="0,5,0,18" />

                                    <CheckBox Content="この修正を今後の候補に使う"
                                              IsChecked="{Binding RememberCorrection}"
                                              Margin="0,0,0,18"
                                              Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="14"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="0,1,0,0"
                                Background="#FFFFFF"
                                Style="{StaticResource VisibleWhenDraftStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="この候補への操作"
                                               Style="{StaticResource ReviewSubheading}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="保存中..."
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource VisibleWhenReviewOperationStyle}" />
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Style="{StaticResource ReviewApplyButton}"
                                            Command="{Binding AcceptDraftCommand}"
                                            ToolTip="レビュー候補を反映して、次の候補へ進みます">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="#FFFFFF" />
                                            <TextBlock Text="適用"
                                                       Foreground="#FFFFFF"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource ReviewSecondaryButton}"
                                            Command="{Binding RejectDraftCommand}"
                                            ToolTip="この候補を反映せず、次の候補へ進みます">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" Foreground="{StaticResource DangerBrush}" />
                                            <TextBlock Text="却下"
                                                       Foreground="{StaticResource DangerBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Style="{StaticResource ReviewSecondaryButton}"
                                            Command="{Binding ApplyManualEditCommand}"
                                            ToolTip="編集欄の内容を手修正として適用します">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE70F;" Style="{StaticResource IconText}" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="手修正"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
