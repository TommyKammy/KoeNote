<UserControl x:Class="KoeNote.App.Controls.ReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:KoeNote.App.Models">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="VisibleWhenDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}" Padding="18">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="推敲レビュー"
                               Style="{StaticResource SectionTitle}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Button Padding="7,4" MinWidth="0" Command="{Binding SelectPreviousDraftCommand}" ToolTip="前の候補">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                        <TextBlock Text="{Binding DraftPositionText}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="7,0" />
                        <Button Padding="7,4" MinWidth="0" Command="{Binding SelectNextDraftCommand}" ToolTip="次の候補">
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Padding="7,4"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Command="{Binding CloseDetailPanelCommand}"
                            ToolTip="閉じる">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                    </Button>

                    <WrapPanel Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Margin="0,10,0,0"
                               Style="{StaticResource VisibleWhenDraftStyle}">
                        <Border Background="#FFF7ED" CornerRadius="12" Padding="9,4" Margin="0,0,8,6">
                            <TextBlock Text="{Binding Confidence, StringFormat=信頼度 {0:P0}}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#FEF3C7" CornerRadius="12" Padding="10,5" Margin="0,0,8,6">
                            <TextBlock Text="{Binding ReviewIssueType}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>
                </Grid>

                <Border Style="{StaticResource VisibleWhenNoDraftStyle}"
                        Background="#FAFBFC"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="推敲候補はありません"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="ASR結果が十分に自然な場合、ここには候補が表示されません。"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Style="{StaticResource VisibleWhenDraftStyle}">
                    <TextBlock Text="原文" Style="{StaticResource MutedText}" />
                    <TextBox Text="{Binding OriginalText, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="82"
                             Margin="0,5,0,14"
                             Background="#FAFBFC" />

                    <TextBlock Text="提案文" Style="{StaticResource MutedText}" Margin="0,0,0,7" />
                    <TextBox Text="{Binding SuggestedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             MinHeight="82"
                             Margin="0,0,0,14"
                             Background="#F7FCF9"
                             BorderBrush="#B7D8C4" />

                    <TextBlock Text="差分" Style="{StaticResource MutedText}" />
                    <Border Background="#FAFBFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,5,0,14">
                        <ItemsControl ItemsSource="{Binding DiffTokens}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="3,1" Margin="0,0,2,2" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                        <Setter Property="Background" Value="{StaticResource DangerLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                        <Setter Property="Background" Value="#FFF7ED" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextTrimming="None" LineHeight="20">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="理由" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding ReviewReason}" TextWrapping="Wrap" TextTrimming="None" LineHeight="21" Margin="0,5,0,18" />

                    <CheckBox Content="この修正を今後の候補に使う"
                              IsChecked="{Binding RememberCorrection}"
                              Margin="0,0,0,14"
                              Foreground="{StaticResource MutedBrush}" />

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource OutlineSuccessButton}" Padding="12,13" MinHeight="46" Command="{Binding AcceptDraftCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="採用" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource OutlineDangerButton}" Padding="12,13" MinHeight="46" Command="{Binding RejectDraftCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" Foreground="{StaticResource DangerBrush}" />
                                <TextBlock Text="却下" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource OutlineNeutralButton}" Padding="12,13" MinHeight="46" Command="{Binding ApplyManualEditCommand}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE70F;" Style="{StaticResource IconText}" Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="手修正" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <Border Background="#FAFBFC" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="ASRコンテキスト" Style="{StaticResource SectionTitle}" FontSize="14" Margin="0,0,0,10" />
                        <TextBlock Text="Context" Style="{StaticResource MutedText}" />
                        <TextBox Text="{Binding AsrContextText, UpdateSourceTrigger=PropertyChanged}" MinHeight="62" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,12" />
                        <TextBlock Text="Hotwords" Style="{StaticResource MutedText}" />
                        <TextBox Text="{Binding AsrHotwordsText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" TextWrapping="Wrap" AcceptsReturn="True" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
