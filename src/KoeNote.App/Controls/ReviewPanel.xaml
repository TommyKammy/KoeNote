<UserControl x:Class="KoeNote.App.Controls.ReviewPanel"
             x:Name="ReviewPanelRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls"
             xmlns:models="clr-namespace:KoeNote.App.Models">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenSummaryStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSummaryContent}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenNoSummaryStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSummaryContent}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenSummaryRunningStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSummaryStageRunning}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReviewSubheading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="InspectorMetaLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="InspectorMetaValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="InspectorSectionCard" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="InspectorTabPill" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Padding="14,12,14,10"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="AI アシスト"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="14"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="10"
                                    Padding="7,2"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource VisibleWhenDraftStyle}">
                                <TextBlock Text="{Binding DraftPositionText}"
                                           Foreground="#FFFFFF"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="選択中の作業コンテキストとAI候補をまとめて確認します。"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Style="{StaticResource VisibleWhenDraftStyle}">
                        <Button Padding="7,4"
                                MinWidth="0"
                                Command="{Binding SelectPreviousDraftCommand}"
                                ToolTip="前の候補">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                        <TextBlock Text="{Binding DraftPositionText}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="7,0" />
                        <Button Padding="7,4"
                                MinWidth="0"
                                Command="{Binding SelectNextDraftCommand}"
                                ToolTip="次の候補">
                            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                        </Button>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="28"
                            Height="28"
                            Padding="0"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"
                            Command="{Binding CloseDetailPanelCommand}"
                            ToolTip="閉じる">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowCloseButton, ElementName=ReviewPanelRoot}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12">
                    <WrapPanel Margin="0,0,0,12">
                        <Border Style="{StaticResource InspectorTabPill}"
                                Background="{StaticResource AccentLightBrush}"
                                BorderBrush="{StaticResource AccentBrush}">
                            <TextBlock Text="整文候補"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Style="{StaticResource InspectorTabPill}">
                            <TextBlock Text="要約"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Style="{StaticResource InspectorTabPill}">
                            <TextBlock Text="表記ゆれ"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>

                    <Border Style="{StaticResource InspectorSectionCard}"
                            Background="#F8FAFC">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="対象" Style="{StaticResource InspectorMetaLabel}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DetailInspectorTargetText}"
                                       Style="{StaticResource InspectorMetaValue}" />

                            <TextBlock Grid.Row="1"
                                       Text="ビュー"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource InspectorMetaLabel}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding DetailInspectorCurrentTabText}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource InspectorMetaValue}" />

                            <TextBlock Grid.Row="2"
                                       Text="セグメント"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource InspectorMetaLabel}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding DetailInspectorSegmentText}"
                                       Margin="0,7,0,0"
                                       Style="{StaticResource InspectorMetaValue}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InspectorSectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource LucideInlineIconBadge}"
                                        Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="4">
                                    <Path Style="{StaticResource LucidePathIcon}"
                                          Width="14"
                                          Height="14"
                                          Stroke="{StaticResource AccentBrush}"
                                          Data="M12 3l1.9 5.7L20 10l-5.3 3.1L15 19l-3-4.3L9 19l.3-5.9L4 10l6.1-1.3z" />
                                </Border>
                                <TextBlock Text="整文候補"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource VisibleWhenDraftStyle}">
                                <Button Padding="7,4"
                                        MinWidth="0"
                                        Command="{Binding SelectPreviousDraftCommand}"
                                        ToolTip="前の候補">
                                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                                <TextBlock Text="{Binding DraftPositionText}"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="7,0" />
                                <Button Padding="7,4"
                                        MinWidth="0"
                                        Command="{Binding SelectNextDraftCommand}"
                                        ToolTip="次の候補">
                                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,12,0,0">
                                <controls:ReviewDraftEmptyState />

                                <StackPanel Style="{StaticResource VisibleWhenDraftStyle}">
                                    <WrapPanel Margin="0,0,0,12">
                                        <Border Background="#FFF7ED" CornerRadius="12" Padding="9,4" Margin="0,0,8,6">
                                            <TextBlock Text="{Binding Confidence, StringFormat=信頼度 {0:P0}}"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="#FEF3C7" CornerRadius="12" Padding="10,5" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding ReviewIssueType}"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Text="原文" Style="{StaticResource ReviewSubheading}" />
                                    <TextBox Text="{Binding OriginalText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             MinHeight="58"
                                             Margin="0,5,0,12"
                                             Background="#FFFFFF"
                                             PreviewMouseLeftButtonUp="FocusDraftSegmentOnClick" />

                                    <Grid Margin="0,0,0,7">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="候補案" Style="{StaticResource ReviewSubheading}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="編集してから適用できます"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBox Text="{Binding SuggestedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"
                                             MinHeight="72"
                                             Margin="0,0,0,12"
                                             Background="#F7FCF9"
                                             BorderBrush="#B7D8C4" />

                                    <TextBlock Text="差分" Style="{StaticResource ReviewSubheading}" />
                                    <Border Background="#FFFFFF"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,5,0,12"
                                            PreviewMouseLeftButtonUp="FocusDraftSegmentOnClick">
                                        <ItemsControl ItemsSource="{Binding DiffTokens}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="3,1" Margin="0,0,2,2" CornerRadius="4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                                        <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                                        <Setter Property="Background" Value="{StaticResource DangerLightBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                                        <Setter Property="Background" Value="#FFF7ED" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextTrimming="None" LineHeight="20">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Inserted}">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Deleted}">
                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:DiffKind.Replaced}">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <TextBlock Text="理由" Style="{StaticResource ReviewSubheading}" />
                                    <TextBlock Text="{Binding ReviewReason}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               LineHeight="21"
                                               Margin="0,5,0,14" />

                                    <CheckBox Content="この修正を今後の候補に使う"
                                              IsChecked="{Binding RememberCorrection}"
                                              Margin="0,0,0,14"
                                              Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <controls:ReviewDraftActionBar Margin="0,0,0,12" />

                    <Border Style="{StaticResource InspectorSectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource LucideInlineIconBadge}"
                                        Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="4">
                                    <Path Style="{StaticResource LucidePathIcon}"
                                          Width="14"
                                          Height="14"
                                          Stroke="{StaticResource AccentBrush}"
                                          Data="M10 5h11M10 12h11M10 19h11M3 10l3-3-3-3M3 20l3-3-3-3" />
                                </Border>
                                <TextBlock Text="要約"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="本文が更新されています"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSummaryStale}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="生成中"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           Style="{StaticResource VisibleWhenSummaryRunningStyle}" />
                                <Button Command="{Binding RunPostSummaryCommand}"
                                        ToolTip="{Binding SummaryActionToolTip}"
                                        MinWidth="90"
                                        Height="28"
                                        Padding="10,4"
                                        Style="{StaticResource OutlineSuccessButton}">
                                    <TextBlock Text="{Binding SummaryActionText}"
                                               Foreground="#FFFFFF"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Button>
                            </StackPanel>

                        <Grid Grid.Row="1"
                              Grid.ColumnSpan="2"
                              Style="{StaticResource VisibleWhenNoSummaryStyle}">
                            <Border Background="#FFFFFF"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Grid Width="34"
                                          Height="34"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,10">
                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="1.18" ScaleY="1.18" CenterX="17" CenterY="17" />
                                        </Grid.RenderTransform>
                                        <Path Fill="#E9E2F4"
                                              Data="M8 3H19L25 9V28H8Z" />
                                        <Path Fill="#CDBDE7"
                                              Data="M19 3V9H25Z" />
                                        <Path Stroke="#B9A7D6"
                                              StrokeThickness="1.35"
                                              StrokeStartLineCap="Round"
                                              Data="M11 12.5H21M11 16.5H21M11 20.5H18" />
                                        <Path Fill="#F97316"
                                              Data="M18.5 24L25.5 17C26.1 16.4 27.1 16.4 27.7 17L28.3 17.6C28.9 18.2 28.9 19.2 28.3 19.8L21.3 26.8L17.9 27.4Z" />
                                        <Path Fill="#7C3AED"
                                              Data="M17.9 27.4L18.5 24L21.3 26.8Z" />
                                        <Path Stroke="#FFFFFF"
                                              StrokeThickness="1.15"
                                              StrokeStartLineCap="Round"
                                              Data="M24.7 17.8L27.5 20.6" />
                                    </Grid>
                                    <TextBlock Text="要約はまだありません"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="「生成」を押すとAIが要約を作成します"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBox Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding SummaryContentDisplay, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="128"
                                 BorderThickness="0"
                                 Background="#FAFBFC"
                                 Padding="12"
                                 Style="{StaticResource VisibleWhenSummaryStyle}" />
                        </Grid>
                    </Border>

                    <Border Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         VerticalAlignment="Center"
                                         Margin="0,0,7,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanRunSelectedJob}" Value="False">
                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Text" Value="システム正常" />
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanRunSelectedJob}" Value="False">
                                                    <Setter Property="Text" Value="要確認" />
                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RunPreflightSummary}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
