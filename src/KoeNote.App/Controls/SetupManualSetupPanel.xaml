<UserControl x:Class="KoeNote.App.Controls.SetupManualSetupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Expander Header="詳細設定: オフライン/ローカル導入">
        <Border Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,8,0,14">
            <StackPanel>
                <TextBlock Text="オンライン導入が使えない場合は、ローカルモデルやoffline model packを指定できます。"
                           Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="88" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ローカル"
                               Foreground="#64748B"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SetupLocalModelPath, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="220"
                             MinHeight="34" />
                    <Button Grid.Column="2"
                            Command="{Binding SetupRegisterLocalAsrCommand}"
                            Padding="8,7"
                            Margin="10,0,0,0">
                        <TextBlock Text="ASR登録" FontSize="12" />
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding SetupRegisterLocalReviewCommand}"
                            Padding="8,7"
                            Margin="10,0,0,0">
                        <TextBlock Text="LLM登録" FontSize="12" />
                    </Button>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="98" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="オフライン"
                               Foreground="#64748B"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding SetupOfflineModelPackPath, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="220"
                             MinHeight="34" />
                    <Button Grid.Column="2"
                            Command="{Binding SetupImportOfflinePackCommand}"
                            Padding="8,7"
                            Margin="10,0,0,0">
                        <TextBlock Text="Pack導入" FontSize="12" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Expander>
</UserControl>
