<UserControl x:Class="KoeNote.App.Controls.SetupWizardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="0,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox ItemsSource="{Binding SetupSteps}"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="0,2,12,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#334155"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="22,0,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding SetupStatusSummary}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <Border Background="#FFFFFF"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="モデル設定"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ASR"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SetupAsrModelChoices}"
                                          SelectedItem="{Binding SelectedSetupAsrModel, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260"
                                          MinHeight="34" />
                                <Button Grid.Column="2"
                                        Command="{Binding SetupDownloadAsrCommand}"
                                        Padding="10,7"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="ダウンロード" FontSize="12" FontWeight="SemiBold" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="話者識別"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SetupDiarizationRuntimeSummary}"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding SetupDiarizationRuntimeSummary}" />
                                <Button Grid.Column="2"
                                        Command="{Binding SetupInstallDiarizationRuntimeCommand}"
                                        Padding="10,7"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="追加導入" FontSize="12" FontWeight="SemiBold" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="推敲 LLM"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SetupReviewModelChoices}"
                                          SelectedItem="{Binding SelectedSetupReviewModel, Mode=TwoWay}"
                                          DisplayMemberPath="DisplayName"
                                          MinWidth="260"
                                          MinHeight="34" />
                                <Button Grid.Column="2"
                                        Command="{Binding SetupDownloadReviewCommand}"
                                        Padding="10,7"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="ダウンロード" FontSize="12" FontWeight="SemiBold" />
                                </Button>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="保存先"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SetupStorageRoot}"
                                           Foreground="#64748B"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip="{Binding SetupStorageRoot}" />
                                <Button Grid.Column="2"
                                        Command="{Binding SetupChooseStorageRootCommand}"
                                        Padding="10,7"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="変更" FontSize="12" />
                                </Button>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="120,0,0,14">
                                <Button Command="{Binding SetupAcceptLicensesCommand}"
                                        Padding="12,7"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="ライセンスに同意" FontSize="12" />
                                </Button>
                                <Button Command="{Binding SetupRunSmokeCommand}"
                                        Padding="12,7">
                                    <TextBlock Text="最終確認を実行" FontSize="12" />
                                </Button>
                            </StackPanel>

                            <Border Background="#F8FAFC"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ModelDownloadProgressSummary}"
                                               Foreground="#64748B"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ModelDownloadProgressText}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               Margin="12,0,0,0" />
                                    <ProgressBar Grid.Row="1"
                                                 Grid.ColumnSpan="2"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding ModelDownloadProgressPercent, Mode=OneWay}"
                                                 IsIndeterminate="{Binding IsModelDownloadProgressIndeterminate}"
                                                 Height="8"
                                                 Margin="0,10,0,0" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Expander Header="手動セットアップ（上級者向け）"
                              Margin="0,0,0,14">
                        <Border Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="オンライン導入でうまくいかない場合だけ、ローカルモデルまたは offline model pack を指定してください。"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="88" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ローカル"
                                               Foreground="#64748B"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SetupLocalModelPath, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="220"
                                             MinHeight="34" />
                                    <Button Grid.Column="2"
                                            Command="{Binding SetupRegisterLocalAsrCommand}"
                                            Padding="8,7"
                                            Margin="10,0,0,0">
                                        <TextBlock Text="ASR登録" FontSize="12" />
                                    </Button>
                                    <Button Grid.Column="3"
                                            Command="{Binding SetupRegisterLocalReviewCommand}"
                                            Padding="8,7"
                                            Margin="10,0,0,0">
                                        <TextBlock Text="LLM登録" FontSize="12" />
                                    </Button>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="98" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="オフライン"
                                               Foreground="#64748B"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SetupOfflineModelPackPath, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="220"
                                             MinHeight="34" />
                                    <Button Grid.Column="2"
                                            Command="{Binding SetupImportOfflinePackCommand}"
                                            Padding="8,7"
                                            Margin="10,0,0,0">
                                        <TextBlock Text="Pack導入" FontSize="12" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Header="詳細なシステム情報を表示">
                        <Border Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="モデル監査"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding SetupModelAudits}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="96"
                                         Margin="0,0,0,16">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ModelId}" Foreground="#334155" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding ChecksumDetail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding ManifestDetail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="{Binding LicenseDetail}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="環境チェック"
                                           FontWeight="SemiBold"
                                           Foreground="#334155"
                                           Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding SetupSmokeChecks}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="136">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="#334155" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding IsOk}" Foreground="{StaticResource AccentBrush}" FontSize="12" />
                                                <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="#64748B" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
