<UserControl x:Class="KoeNote.App.Controls.SetupModelSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Background="#FFFFFF"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,14">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Style="{StaticResource LucideCardIconBadge}">
                    <Path Style="{StaticResource LucidePathIcon}"
                          Data="M12 20v2M12 2v2M17 20v2M17 2v2M2 12h2M2 17h2M2 7h2M20 12h2M20 17h2M20 7h2M7 20v2M7 2v2M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2M9 8h6a1 1 0 0 1 1 1v6a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1" />
                </Border>
                <TextBlock Text="モデル設定"
                           Style="{StaticResource SectionTitle}"
                           Margin="0"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="構成"
                           Foreground="#64748B"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1">
                    <ComboBox ItemsSource="{Binding SetupModelPresetChoices}"
                              SelectedItem="{Binding SelectedSetupModelPreset, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              MinWidth="0"
                              MinHeight="34"
                              HorizontalAlignment="Stretch"
                              ToolTip="{Binding SelectedSetupModelPresetDescription}"
                              TextSearch.TextPath="DisplayName" />
                    <TextBlock Text="{Binding SelectedSetupModelPresetDescription}"
                               Foreground="#64748B"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <Border Background="#ECFDF5"
                            BorderBrush="#A7F3D0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,8,0,0">
                        <TextBlock Text="{Binding SetupPresetRecommendationSummary}"
                                   Foreground="#047857"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SetupPresetRecommendationDetail}" />
                    </Border>

                    <Border Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Style="{StaticResource LucideInlineIconBadge}"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11">
                                    <Path Style="{StaticResource LucidePathIcon}"
                                          Width="13"
                                          Height="13"
                                          Data="M10 16h.01M2.212 11.577a2 2 0 0 0-.212.896V18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5.527a2 2 0 0 0-.212-.896L18.55 5.11A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11zM21.946 12.013H2.054M6 16h.01" />
                                </Border>
                                <TextBlock Text="導入内容"
                                           Foreground="#334155"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding SetupInstallPlanItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="104" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="76" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#334155"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Summary}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Summary}"
                                                       Margin="8,0,8,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Status}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFBEB"
                            BorderBrush="#FCD34D"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,10,0,0"
                            Visibility="{Binding ShowSetupLicenseNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="ライセンス確認"
                                       Foreground="#92400E"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding SetupLicenseNoticeText}"
                                       Foreground="#78350F"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding ShowSetupInlineInstallAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Command="{Binding SetupInstallSelectedPresetCommand}"
                                Padding="14,9"
                                MinWidth="152"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding SetupPrimaryInstallActionText}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Button>
                        <TextBlock Text="{Binding SetupPrimaryInstallSummary}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Expander Header="詳細設定: モデルと保存先を手動で選ぶ"
                      Margin="0,0,0,14">
                <StackPanel Margin="0,10,0,0">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ASR"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SetupAsrModelChoices}"
                                  SelectedItem="{Binding SelectedSetupAsrModel, Mode=TwoWay}"
                                  DisplayMemberPath="SetupDisplayName"
                                  MinWidth="0"
                                  MinHeight="34"
                                  HorizontalAlignment="Stretch"
                                  ToolTip="{Binding SelectedSetupAsrModel.SetupDisplayName}"
                                  TextSearch.TextPath="SetupDisplayName" />
                        <Button Grid.Column="2"
                                Command="{Binding SetupDownloadAsrCommand}"
                                Padding="10,7"
                                MinWidth="92"
                                Margin="10,0,0,0">
                            <TextBlock Text="導入" FontSize="12" FontWeight="SemiBold" />
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ASR GPU"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SetupAsrCudaRuntimeSummary}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding SetupAsrCudaRuntimeSummary}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GPU高速化"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SetupCudaReviewRuntimeSummary}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding SetupCudaReviewRuntimeSummary}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="話者識別"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SetupDiarizationRuntimeSummary}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding SetupDiarizationRuntimeSummary}" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="整文LLM"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding SetupReviewModelChoices}"
                                  SelectedItem="{Binding SelectedSetupReviewModel, Mode=TwoWay}"
                                  DisplayMemberPath="SetupDisplayName"
                                  MinWidth="0"
                                  MinHeight="34"
                                  HorizontalAlignment="Stretch"
                                  ToolTip="{Binding SelectedSetupReviewModel.SetupDisplayName}"
                                  TextSearch.TextPath="SetupDisplayName" />
                        <Button Grid.Column="2"
                                Command="{Binding SetupDownloadReviewCommand}"
                                Padding="10,7"
                                MinWidth="92"
                                Margin="10,0,0,0">
                            <TextBlock Text="導入" FontSize="12" FontWeight="SemiBold" />
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="保存先"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SetupStorageRoot}"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding SetupStorageRoot}" />
                        <Button Grid.Column="2"
                                Command="{Binding SetupChooseStorageRootCommand}"
                                Padding="10,7"
                                MinWidth="92"
                                Margin="10,0,0,0">
                            <TextBlock Text="変更" FontSize="12" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Expander>

            <StackPanel Orientation="Horizontal"
                        Margin="92,0,0,14"
                        Visibility="{Binding ShowSetupSmokeAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Command="{Binding SetupRunSmokeCommand}"
                        Padding="12,7">
                    <TextBlock Text="最終確認を実行" FontSize="12" />
                </Button>
            </StackPanel>

            <Border Background="#F8FAFC"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ModelDownloadProgressSummary}"
                               Foreground="#64748B"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ModelDownloadProgressText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="12"
                               Margin="12,0,0,0" />
                    <ProgressBar Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ModelDownloadProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsModelDownloadProgressIndeterminate}"
                                 Height="8"
                                 Margin="0,10,0,0" />
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
