<UserControl x:Class="KoeNote.App.Controls.ReviewDraftEmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="VisibleWhenNoDraftStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasReviewDraft}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource VisibleWhenNoDraftStyle}"
            Background="#FAFBFC"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#x2728;"
                       FontFamily="Segoe UI Emoji"
                       FontSize="34"
                       Foreground="#F59E0B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />
            <TextBlock Text="整文候補はありません"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       Margin="0,0,0,6" />
            <TextBlock Text="「整文」タブで結果を確認し、&#x0A;承認すると候補がここに表示されます"
                       Style="{StaticResource MutedText}"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
