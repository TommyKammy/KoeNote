<UserControl x:Class="KoeNote.App.Controls.StatusBarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StoragePath, StringFormat=保存先: {0}}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FirstRunSummary}" ToolTip="{Binding FirstRunDetail}" Style="{StaticResource MutedText}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding DiskFreeSummary}" Style="{StaticResource MutedText}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding MemorySummary}" Style="{StaticResource MutedText}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding CpuSummary}" Style="{StaticResource MutedText}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding GpuUsageSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGpuUsageUnknown}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
</UserControl>
