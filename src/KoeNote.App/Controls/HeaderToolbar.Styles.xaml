<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<SolidColorBrush x:Key="HeaderTextBrush" Color="#1F2937" />
<SolidColorBrush x:Key="HeaderInfoLabelBrush" Color="#9AA3AF" />
<SolidColorBrush x:Key="HeaderInfoValueBrush" Color="#667085" />
<SolidColorBrush x:Key="HeaderHoverBrush" Color="#F8FAFC" />
<SolidColorBrush x:Key="HeaderPressedBrush" Color="#F1F5F9" />
<SolidColorBrush x:Key="HeaderSeparatorBrush" Color="#EEF0F2" />

<Style x:Key="HeaderButtonBase" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPressedBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.38" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<Style x:Key="HeaderOutlineButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Height" Value="34" />
    <Setter Property="MinWidth" Value="104" />
    <Setter Property="Padding" Value="13,0" />
    <Setter Property="Margin" Value="0,0,10,0" />
</Style>

<Style x:Key="HeaderRunMenuButton" TargetType="Button" BasedOn="{StaticResource HeaderOutlineButton}">
    <Setter Property="Width" Value="34" />
    <Setter Property="MinWidth" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="-6,0,10,0" />
</Style>

<Style x:Key="HeaderGhostButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="14,0" />
</Style>

<Style x:Key="HeaderReviewToggle" TargetType="ToggleButton">
    <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Height" Value="34" />
    <Setter Property="MinWidth" Value="104" />
    <Setter Property="Padding" Value="13,0" />
    <Setter Property="Margin" Value="0,0,10,0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ToggleButton">
                <Border x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentLightBrush}" />
                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True" />
                            <Condition Property="IsChecked" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter TargetName="Chrome" Property="Background" Value="#DCFCE7" />
                    </MultiTrigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.45" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
    <Style.Triggers>
        <DataTrigger Binding="{Binding IsRunInProgress}" Value="True">
            <Setter Property="IsEnabled" Value="False" />
        </DataTrigger>
    </Style.Triggers>
</Style>

<Style x:Key="HeaderIconButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="2,0,0,0" />
</Style>

<Style x:Key="HeaderToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Margin" Value="0,0,8,0" />
    <Setter Property="Opacity" Value="0.92" />
</Style>

<Style x:Key="HeaderRunIcon" TargetType="TextBlock" BasedOn="{StaticResource HeaderToolIcon}">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Margin" Value="0,0,9,0" />
</Style>

<Style x:Key="HeaderIconOnlyText" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
    <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
</Style>

<Style x:Key="HeaderToolText" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
</Style>

<Style x:Key="HeaderInfoLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource HeaderInfoLabelBrush}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="VerticalAlignment" Value="Center" />
</Style>

<Style x:Key="HeaderInfoValue" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
</Style>

<Style x:Key="HeaderExportMenuItem" TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinWidth" Value="178" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="10,7" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="MenuItem">
                <Grid>
                    <Border x:Name="ItemChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="CheckMark"
                                       Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="0,0,14,0" />
                            <TextBlock x:Name="SubmenuArrow"
                                       Grid.Column="2"
                                       Text="&#xE76C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="{StaticResource HeaderInfoValueBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Right"
                           PopupAnimation="Fade">
                        <Border Background="#FFFFFF"
                                BorderBrush="#DDE5EE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6"
                                Margin="4,0,0,0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="3"
                                                  Opacity="0.14"
                                                  Color="#111827" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </Popup>
                </Grid>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter TargetName="ItemChrome" Property="Background" Value="#F8FAFC" />
                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#E5EAF0" />
                    </Trigger>
                    <Trigger Property="IsSubmenuOpen" Value="True">
                        <Setter TargetName="ItemChrome" Property="Background" Value="#F1F5F9" />
                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#DDE5EE" />
                    </Trigger>
                    <Trigger Property="HasItems" Value="True">
                        <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.42" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<Style x:Key="HeaderDropdownMenu" TargetType="ContextMenu">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#DDE5EE" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ContextMenu">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20"
                                          ShadowDepth="4"
                                          Opacity="0.16"
                                          Color="#111827" />
                    </Border.Effect>
                    <StackPanel IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<Style x:Key="HeaderMenuSeparator" TargetType="Separator">
    <Setter Property="Margin" Value="8,5" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Separator">
                <Border Height="1"
                        Background="{StaticResource HeaderSeparatorBrush}" />
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
</ResourceDictionary>

