<UserControl x:Class="KoeNote.App.Controls.DomainPresetTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="DomainPresetSection" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="DomainPresetFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="DomainPresetSectionTitle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" MinWidth="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.9*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource DomainPresetSection}">
                <StackPanel>
                    <TextBlock Text="辞書プリセット" Style="{StaticResource DomainPresetSectionTitle}" />

                    <Button Command="{Binding ImportDomainPresetCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinHeight="34"
                            HorizontalAlignment="Left"
                            Padding="14,6"
                            ToolTip="専門領域プリセット JSON を読み込みます。">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;"
                                       Style="{StaticResource IconText}"
                                       Foreground="#FFFFFF" />
                            <TextBlock Text="JSONを読み込み"
                                       Foreground="#FFFFFF"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding LoadedDomainPresetSummary}"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,6" />

                    <TextBox Text="{Binding LoadedDomainPresetDetails, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="160"
                             MaxHeight="260"
                             Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Command="{Binding ApplyLoadedDomainPresetCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                Padding="14,6"
                                ToolTip="読み込み済みプリセットをインポートします。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;"
                                           Style="{StaticResource IconText}"
                                           Foreground="#FFFFFF" />
                                <TextBlock Text="インポート"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ClearDomainPresetCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinHeight="34"
                                Padding="14,6"
                                Margin="8,0,0,0"
                                ToolTip="選択したプリセットをクリアします。">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           Style="{StaticResource IconText}"
                                           Foreground="#FFFFFF" />
                                <TextBlock Text="クリア"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DomainPresetSection}">
                <StackPanel>
                    <TextBlock Text="インポート履歴" Style="{StaticResource DomainPresetSectionTitle}" />
                    <TextBlock Text="読み込んだ辞書プリセットの履歴を選択して、内容確認やクリアに使います。"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <ComboBox ItemsSource="{Binding DomainPresetImports}"
                              SelectedItem="{Binding SelectedDomainPresetImport, Mode=TwoWay}"
                              DisplayMemberPath="Summary"
                              MinHeight="32" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
