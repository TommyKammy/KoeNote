<UserControl x:Class="KoeNote.App.Controls.HeaderToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#333333" />
        <SolidColorBrush x:Key="HeaderInfoLabelBrush" Color="#AAAAAA" />
        <SolidColorBrush x:Key="HeaderInfoValueBrush" Color="#777777" />
        <SolidColorBrush x:Key="HeaderHoverBrush" Color="#F5F6F7" />
        <SolidColorBrush x:Key="HeaderSeparatorBrush" Color="#EEF0F2" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenBrush" Color="#DDF7E8" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenHoverBrush" Color="#C8F0DA" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenPressedBrush" Color="#B5E7CA" />

        <Style x:Key="HeaderGhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#ECEFF1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="HeaderPrimaryActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="Background" Value="{StaticResource HeaderPrimaryGreenBrush}" />
            <Setter Property="BorderBrush" Value="#8DD6AD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#2F8F5B" BlurRadius="10" ShadowDepth="0" Opacity="0.12" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPrimaryGreenHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPrimaryGreenPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                                <Setter Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderPrimaryToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="HeaderPrimaryToolText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderToolText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoLabelBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BorderBrushSoft}"
            Padding="18,4">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                <Image Source="pack://application:,,,/Resources/KoeNoteBirdMono.png"
                       Width="23"
                       Height="23"
                       Stretch="Uniform"
                       Opacity="0.82"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       ToolTip="KoeNote" />
                <TextBlock Text="KoeNote"
                           FontFamily="Segoe UI"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource HeaderTextBrush}"
                           VerticalAlignment="Center"
                           LineStackingStrategy="BlockLineHeight"
                           LineHeight="24" />
            </StackPanel>

            <Border Grid.Column="1"
                    Width="0.5"
                    Height="24"
                    Background="{StaticResource HeaderSeparatorBrush}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button Style="{StaticResource HeaderPrimaryActionButton}"
                        Command="{Binding AddAudioCommand}"
                        ToolTip="最初に音声ファイルを追加します">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8E5;" Style="{StaticResource HeaderPrimaryToolIcon}" />
                        <TextBlock Text="音声追加" Style="{StaticResource HeaderPrimaryToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding RunSelectedJobCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE768;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="実行" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding CancelCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE711;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="中止" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Column="3"
                    Width="0.5"
                    Height="24"
                    Background="{StaticResource HeaderSeparatorBrush}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />

            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportTxtCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="TXT" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportJsonCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE943;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="JSON" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportSrtCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="SRT" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportDocxCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="DOCX" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <CheckBox IsChecked="{Binding IncludeExportTimestamps, Mode=TwoWay}"
                          Content="時刻"
                          VerticalAlignment="Center"
                          Margin="6,0,6,0"
                          FontSize="11"
                          Foreground="{StaticResource HeaderInfoValueBrush}"
                          ToolTip="TXT / Markdown / DOCX 出力にタイムスタンプを含めます" />
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenSettingsCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE713;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="設定" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding OpenSetupCommand}" ToolTip="{Binding SetupPlaceholderText}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE9D9;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="セットアップ" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ShowModelCatalogCommand}" Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8B7;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="モデル" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="GPU" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding GpuSummary}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="130"
                           ToolTip="{Binding GpuSummary}"
                           Margin="0,0,12,0" />
                <TextBlock Text="ASR" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding AsrModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="145"
                           ToolTip="{Binding AsrModel}"
                           Margin="0,0,12,0" />
                <TextBlock Text="REVIEW" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ReviewModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="105"
                           ToolTip="{Binding ReviewModel}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
