<UserControl x:Class="KoeNote.App.Controls.HeaderToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="HeaderToolbar.Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DrawingImage x:Key="ExportTextIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#EFE8F8" Geometry="M4,2 L12,2 L15,5 L15,16 L4,16 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#DFD4EE" Thickness="0.7" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M12,2 L15,5 L12,5 Z" />
                        <GeometryDrawing Geometry="M7,8 L12,8 M7,10.5 L12,10.5 M7,13 L10.5,13">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#9A8DB8" Thickness="1.1" StartLineCap="Round" EndLineCap="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportMarkdownIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Geometry="M4,4 L4,15 M4,4 L15,4 M15,4 L15,15 M4,15 L15,15 M4,10 L15,10 M9.5,4 L9.5,15">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#1F2937" Thickness="1.1" StartLineCap="Square" EndLineCap="Square" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportWordIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#EEE8F7" Geometry="M4,2 L12,2 L15,5 L15,16 L4,16 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#DDD2EE" Thickness="0.7" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M12,2 L15,5 L12,5 Z" />
                        <GeometryDrawing Geometry="M7,8 L12,8 M7,10.5 L11,10.5">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#A094B8" Thickness="1" StartLineCap="Round" EndLineCap="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#F97316" Geometry="M10.2,13.5 L14.1,9.6 L16,11.5 L12.1,15.4 L9.6,16.1 Z" />
                        <GeometryDrawing Brush="#334155" Geometry="M9.6,16.1 L10.2,13.5 L12.1,15.4 Z" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportExcelIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#E8F7EF" Geometry="M4,2 L12,2 L15,5 L15,16 L4,16 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#B9E7CA" Thickness="0.7" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M12,2 L15,5 L12,5 Z" />
                        <GeometryDrawing Geometry="M6,8 L13,8 M6,11 L13,11 M8.5,6 L8.5,14 M11,6 L11,14">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#16A34A" Thickness="1" StartLineCap="Round" EndLineCap="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportJsonIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#F1ECFA" Geometry="M4,2 L12,2 L15,5 L15,16 L4,16 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#DED4F2" Thickness="0.7" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M12,2 L15,5 L12,5 Z" />
                        <GeometryDrawing Geometry="M8,6 C6.6,6 6.3,7.1 7,8 C6.3,8.9 6.6,10 8,10 M11,6 C12.4,6 12.7,7.1 12,8 C12.7,8.9 12.4,10 11,10">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#7C5CC0" Thickness="1.15" StartLineCap="Round" EndLineCap="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#7C5CC0" Geometry="M8.8,11.8 A0.8,0.8 0 1 1 8.79,11.8 M11.2,11.8 A0.8,0.8 0 1 1 11.19,11.8" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportCaptionIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#E9DDF8" Geometry="M3,7 C3,4.9 5.2,3.4 8.5,3.4 L10.3,3.4 C13.4,3.4 15.4,4.9 15.4,7 C15.4,9.1 13.4,10.7 10.3,10.7 L8.2,10.7 L5.2,13.1 L6.1,10.5 C4.2,9.9 3,8.7 3,7 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#CDBCEB" Thickness="0.7" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Geometry="M6.2,7.1 L12.2,7.1 M7.2,8.8 L11,8.8">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#8F7EBA" Thickness="0.95" StartLineCap="Round" EndLineCap="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportCopyIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M4,5 L11,5 L11,13 L4,13 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#1F2937" Thickness="1.1" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#FFFFFF" Geometry="M7,8 L14,8 L14,16 L7,16 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#1F2937" Thickness="1.1" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <DrawingImage x:Key="ExportFolderIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#FFF4DE" Geometry="M2.8,6 L7.4,6 L8.8,7.5 L15.8,7.5 L15,15 L3,15 Z">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#F3B755" Thickness="0.8" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#F59E0B" Geometry="M3,8 L16,8 L14.7,15 L2.3,15 Z" />
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <Style x:Key="VisibleWhenReadableExportMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportFormatMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsReadableExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenRawExportMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportFormatMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRawExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenDiffExportMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportUtilityMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsDiffExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenReviewCandidateExportMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportFormatMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsReviewCandidateExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenSummaryExportMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportFormatMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSummaryExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenMergeSpeakerExportOptionMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportToggleMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMergeConsecutiveSpeakersExportOptionVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenCurrentExportTargetCopyMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportUtilityMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCurrentExportTargetCopyVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenCurrentExportTargetToggleMenuItem" TargetType="MenuItem" BasedOn="{StaticResource HeaderExportToggleMenuItem}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCurrentExportTargetCopyVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenSummaryExportSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource HeaderExportSectionLabel}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSummaryExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenSummaryExportSeparator" TargetType="Separator" BasedOn="{StaticResource HeaderMenuSeparator}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSummaryExportMenuVisible}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BorderBrushSoft}"
            Padding="16,6">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="KoeNote"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />

                <Button Style="{StaticResource HeaderRunButton}"
                        Command="{Binding RunSelectedJobCommand}"
                        ToolTip="{Binding RunPreflightDetail}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE768;" Style="{StaticResource HeaderRunIcon}" />
                        <TextBlock Text="実行" Style="{StaticResource HeaderToolText}" Foreground="#FFFFFF" />
                    </StackPanel>
                </Button>

                <Button x:Name="RunMenuButton"
                        Style="{StaticResource HeaderRunMenuButton}"
                        Click="OnRunMenuButtonClick"
                        ToolTip="後から処理を実行">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Style="{StaticResource HeaderDropdownMenu}">
                            <MenuItem Header="レビュー候補を生成"
                                      Command="{Binding RunPostReviewCommand}"
                                      IsEnabled="{Binding CanRunPostReview}"
                                      Style="{StaticResource HeaderExportMenuItem}" />
                            <MenuItem Header="整文を生成"
                                      Command="{Binding RunReadablePolishingCommand}"
                                      IsEnabled="{Binding CanRunReadablePolishing}"
                                      Style="{StaticResource HeaderExportMenuItem}" />
                            <MenuItem Header="要約を実行"
                                      Command="{Binding RunPostSummaryCommand}"
                                      IsEnabled="{Binding CanRunPostSummary}"
                                      Style="{StaticResource HeaderExportMenuItem}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <TextBlock Text="&#xE70D;"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource HeaderInfoValueBrush}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </Button>

                <Button Style="{StaticResource HeaderOutlineButton}"
                        Command="{Binding CancelCommand}"
                        ToolTip="実行中の処理を中止">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE71A;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="中止" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>

                <ToggleButton Style="{StaticResource HeaderReviewToggle}"
                              IsChecked="{Binding EnableReviewStage, Mode=TwoWay}"
                              ToolTip="{Binding ReviewStageToggleToolTip}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="整文"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Grid Width="30"
                              Height="17"
                              Margin="8,0,0,0"
                              ClipToBounds="True">
                            <Border Style="{StaticResource HeaderToggleTrack}" />
                            <Ellipse Style="{StaticResource HeaderToggleThumb}" />
                        </Grid>
                    </StackPanel>
                </ToggleButton>

                <Button x:Name="ExportMenuButton"
                        Style="{StaticResource HeaderExportButton}"
                        Click="OnExportMenuButtonClick"
                        ToolTip="{Binding ContextualExportMenuToolTip}">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                     Style="{StaticResource HeaderDropdownMenu}">
                            <TextBlock Text="書き出し形式" Style="{StaticResource HeaderExportSectionLabel}" />
                            <MenuItem Header="テキスト" Tag=".txt" Command="{Binding ExportReadablePolishedTxtCommand}" Style="{StaticResource VisibleWhenReadableExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportTextIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Markdown" Tag=".md" Command="{Binding ExportReadablePolishedMarkdownCommand}" Style="{StaticResource VisibleWhenReadableExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportMarkdownIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Word 文書" Tag=".docx" Command="{Binding ExportReadablePolishedDocxCommand}" Style="{StaticResource VisibleWhenReadableExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportWordIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Excel" Tag=".xlsx" Command="{Binding ExportReadablePolishedXlsxCommand}" Style="{StaticResource VisibleWhenReadableExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportExcelIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="テキスト" Tag=".txt" Command="{Binding ExportRawTxtCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportTextIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Markdown" Tag=".md" Command="{Binding ExportRawMarkdownCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportMarkdownIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Word 文書" Tag=".docx" Command="{Binding ExportRawDocxCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportWordIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Excel" Tag=".xlsx" Command="{Binding ExportRawXlsxCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportExcelIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="JSON" Tag=".json" Command="{Binding ExportRawJsonCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportJsonIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="字幕 SRT" Tag=".srt" Command="{Binding ExportRawSrtCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportCaptionIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="字幕 VTT" Tag=".vtt" Command="{Binding ExportRawVttCommand}" Style="{StaticResource VisibleWhenRawExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportCaptionIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="テキスト" Tag=".txt" Command="{Binding ExportPolishedTxtCommand}" Style="{StaticResource VisibleWhenReviewCandidateExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportTextIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Markdown" Tag=".md" Command="{Binding ExportPolishedMarkdownCommand}" Style="{StaticResource VisibleWhenReviewCandidateExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportMarkdownIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Word 文書" Tag=".docx" Command="{Binding ExportPolishedDocxCommand}" Style="{StaticResource VisibleWhenReviewCandidateExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportWordIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Excel" Tag=".xlsx" Command="{Binding ExportPolishedXlsxCommand}" Style="{StaticResource VisibleWhenReviewCandidateExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportExcelIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="差分ビューはエクスポート対象外です" IsEnabled="False" Style="{StaticResource VisibleWhenDiffExportMenuItem}">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#8B93A2" FontSize="15" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Style="{StaticResource HeaderMenuSeparator}" />
                            <MenuItem Header="クリップボードにコピー"
                                      Command="{Binding CopyCurrentExportTargetCommand}"
                                      Style="{StaticResource VisibleWhenCurrentExportTargetCopyMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportCopyIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="タイムスタンプを含める"
                                      IsCheckable="True"
                                      IsChecked="{Binding IncludeExportTimestamps, Mode=TwoWay}"
                                      Style="{StaticResource VisibleWhenCurrentExportTargetToggleMenuItem}" />
                            <MenuItem Header="同じ話者をまとめる"
                                      IsCheckable="True"
                                      IsChecked="{Binding MergeConsecutiveSpeakersOnExport, Mode=TwoWay}"
                                      Style="{StaticResource VisibleWhenMergeSpeakerExportOptionMenuItem}" />
                            <Separator Style="{StaticResource VisibleWhenSummaryExportSeparator}" />
                            <TextBlock Text="要約" Style="{StaticResource VisibleWhenSummaryExportSectionLabel}" />
                            <MenuItem Header="Markdown" Tag=".md" Command="{Binding ExportSummaryMarkdownCommand}" Style="{StaticResource VisibleWhenSummaryExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportMarkdownIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="テキスト" Tag=".txt" Command="{Binding ExportSummaryTextCommand}" Style="{StaticResource VisibleWhenSummaryExportMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportTextIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator Style="{StaticResource VisibleWhenSummaryExportSeparator}" />
                            <MenuItem Header="出力フォルダーを開く"
                                      Command="{Binding OpenExportFolderCommand}"
                                      Style="{StaticResource HeaderExportUtilityMenuItem}">
                                <MenuItem.Icon>
                                    <Image Source="{StaticResource ExportFolderIcon}" Style="{StaticResource HeaderExportImageIcon}" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Style="{StaticResource HeaderToolPathIcon}"
                              Data="M14 2v4a2 2 0 0 0 2 2h4M4 7V4a2 2 0 0 1 2-2h8l6 6v12a2 2 0 0 1-2 2H4M2 15h10M9 18l3-3-3-3" />
                        <TextBlock Text="{Binding ContextualExportMenuHeader}" Style="{StaticResource HeaderToolText}" />
                        <TextBlock Text="&#xE70D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource HeaderInfoValueBrush}"
                                   FontSize="11"
                                   Margin="9,1,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="12,0,12,0">
                <Border Background="#F3F5F8"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="2"
                        Margin="0,0,12,0"
                        ToolTip="{Binding MainLayoutModeToolTip}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="標準"
                                     GroupName="MainLayoutMode"
                                     Style="{StaticResource HeaderLayoutRadioButton}"
                                     IsChecked="{Binding IsStandardLayoutSelected, Mode=TwoWay}" />
                        <RadioButton Content="詳細"
                                     GroupName="MainLayoutMode"
                                     Style="{StaticResource HeaderLayoutRadioButton}"
                                     IsChecked="{Binding IsDetailLayoutSelected, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding AppVersionDisplay}"
                           Style="{StaticResource HeaderInfoValue}"
                           ToolTip="{Binding AppVersionToolTip}"
                           Margin="0,0,10,0" />
                <Button Style="{StaticResource HeaderModelBadgeButton}"
                        Command="{Binding OpenSettingsCommand}">
                    <Button.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock Text="{Binding AsrModel, StringFormat=ASR: {0}}" />
                                <TextBlock Text="{Binding HeaderReviewModel, StringFormat=整文: {0}}" />
                                <TextBlock Text="{Binding HeaderSummaryModel, StringFormat=要約: {0}}" />
                            </StackPanel>
                        </ToolTip>
                    </Button.ToolTip>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F916;"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="13"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="{Binding AsrModel}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   MaxWidth="100"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Border Width="0.5"
                        Height="24"
                        Background="{StaticResource HeaderSeparatorBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="設定">
                    <TextBlock Text="&#xE713;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding CheckForUpdatesCommand}"
                        ToolTip="更新を確認">
                    <TextBlock Text="&#xE895;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

