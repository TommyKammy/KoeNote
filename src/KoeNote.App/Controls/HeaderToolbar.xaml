<UserControl x:Class="KoeNote.App.Controls.HeaderToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Padding="22,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="KoeNote" FontSize="22" FontWeight="SemiBold" Margin="0,0,14,0" />
                    <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,1,7,0" />
                    <TextBlock Text="{Binding AppMode}" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GPU" Style="{StaticResource MutedText}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding GpuSummary}" FontSize="12" MaxWidth="190" TextTrimming="CharacterEllipsis" Margin="0,0,18,0" />
                    <TextBlock Text="ASR" Style="{StaticResource MutedText}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding AsrModel}"
                               FontSize="12"
                               MaxWidth="220"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding AsrModel}"
                               Margin="0,0,18,0" />
                    <TextBlock Text="推敲" Style="{StaticResource MutedText}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ReviewModel}" FontSize="12" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Padding="18,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddAudioCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="音声追加" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RunSelectedJobCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" Style="{StaticResource IconText}" />
                                <TextBlock Text="実行" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" />
                                <TextBlock Text="中止" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrushSoft}" Margin="0,6,18,6" />

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button Command="{Binding ExportTxtCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" />
                                <TextBlock Text="TXT" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportJsonCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE943;" Style="{StaticResource IconText}" />
                                <TextBlock Text="JSON" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportSrtCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" />
                                <TextBlock Text="SRT" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportDocxCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" />
                                <TextBlock Text="DOCX" />
                            </StackPanel>
                        </Button>
                        <CheckBox IsChecked="{Binding IncludeExportTimestamps, Mode=TwoWay}"
                                  Content="時刻"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"
                                  FontSize="12"
                                  Foreground="{StaticResource MutedBrush}"
                                  ToolTip="TXT / Markdown / DOCX 出力にタイムスタンプを含めます" />
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource BorderBrushSoft}" Margin="0,6,18,6" />

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding OpenSettingsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource IconText}" />
                                <TextBlock Text="設定" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenSetupCommand}" ToolTip="{Binding SetupPlaceholderText}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" Style="{StaticResource IconText}" />
                                <TextBlock Text="セットアップ" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ShowModelCatalogCommand}" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                                <TextBlock Text="モデル" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
