<UserControl x:Class="KoeNote.App.Controls.HeaderToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#333333" />
        <SolidColorBrush x:Key="HeaderInfoLabelBrush" Color="#9AA3AF" />
        <SolidColorBrush x:Key="HeaderInfoValueBrush" Color="#667085" />
        <SolidColorBrush x:Key="HeaderHoverBrush" Color="#F5F6F7" />
        <SolidColorBrush x:Key="HeaderSeparatorBrush" Color="#EEF0F2" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenBrush" Color="#DDF7E8" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenHoverBrush" Color="#C8F0DA" />
        <SolidColorBrush x:Key="HeaderPrimaryGreenPressedBrush" Color="#B5E7CA" />

        <Style x:Key="HeaderGhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#ECEFF1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderIconButton" TargetType="Button" BasedOn="{StaticResource HeaderGhostButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>

        <Style x:Key="HeaderToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style x:Key="HeaderIconOnlyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderPrimaryActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="Background" Value="{StaticResource HeaderPrimaryGreenBrush}" />
            <Setter Property="BorderBrush" Value="#8DD6AD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#2F8F5B" BlurRadius="10" ShadowDepth="0" Opacity="0.12" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPrimaryGreenHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPrimaryGreenPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                                <Setter Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderPrimaryToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>

        <Style x:Key="HeaderPrimaryToolText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17643C" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderToolText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoLabelBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BorderBrushSoft}"
            Padding="16,5">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button Style="{StaticResource HeaderPrimaryActionButton}"
                        Command="{Binding AddAudioCommand}"
                        ToolTip="音声ファイルを追加します">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8E5;" Style="{StaticResource HeaderPrimaryToolIcon}" />
                        <TextBlock Text="新規インポート" Style="{StaticResource HeaderPrimaryToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}"
                        Command="{Binding RunSelectedJobCommand}"
                        ToolTip="選択中のジョブを実行"
                        Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE768;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="実行" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}"
                        Command="{Binding CancelCommand}"
                        ToolTip="実行中の処理を中止"
                        Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE711;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="中止" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="0.5"
                    Height="24"
                    Background="{StaticResource HeaderSeparatorBrush}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Export"
                           Style="{StaticResource HeaderInfoLabel}"
                           FontWeight="SemiBold"
                           Margin="0,0,6,0" />
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportTxtCommand}" ToolTip="TXTでエクスポート">
                    <TextBlock Text="TXT" Style="{StaticResource HeaderToolText}" />
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportJsonCommand}" ToolTip="JSONでエクスポート" Margin="1,0,0,0">
                    <TextBlock Text="JSON" Style="{StaticResource HeaderToolText}" />
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportSrtCommand}" ToolTip="SRTでエクスポート" Margin="1,0,0,0">
                    <TextBlock Text="SRT" Style="{StaticResource HeaderToolText}" />
                </Button>
                <Button Style="{StaticResource HeaderGhostButton}" Command="{Binding ExportDocxCommand}" ToolTip="DOCXでエクスポート" Margin="1,0,0,0">
                    <TextBlock Text="DOCX" Style="{StaticResource HeaderToolText}" />
                </Button>
                <CheckBox IsChecked="{Binding IncludeExportTimestamps, Mode=TwoWay}"
                          Content="時刻"
                          VerticalAlignment="Center"
                          Margin="6,0,0,0"
                          FontSize="11"
                          Foreground="{StaticResource HeaderInfoValueBrush}"
                          ToolTip="TXT / DOCX 出力にタイムスタンプを含めます" />
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="12,0,12,0">
                <TextBlock Text="ASR" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding AsrModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="118"
                           ToolTip="{Binding AsrModel}"
                           Margin="0,0,12,0" />
                <TextBlock Text="REVIEW" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ReviewModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="96"
                           ToolTip="{Binding ReviewModel}" />
            </StackPanel>

            <StackPanel Grid.Column="4"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Border Width="0.5"
                        Height="24"
                        Background="{StaticResource HeaderSeparatorBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="設定">
                    <TextBlock Text="&#xE713;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenSetupCommand}"
                        ToolTip="{Binding SetupPlaceholderText}">
                    <TextBlock Text="&#xE9D9;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding ShowModelCatalogCommand}"
                        ToolTip="モデル">
                    <TextBlock Text="&#xE8B7;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenLogsCommand}"
                        ToolTip="ログ">
                    <TextBlock Text="&#xE8A5;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding CheckForUpdatesCommand}"
                        ToolTip="更新を確認">
                    <TextBlock Text="&#xE895;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
