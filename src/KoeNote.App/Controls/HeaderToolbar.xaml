<UserControl x:Class="KoeNote.App.Controls.HeaderToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="HeaderInfoLabelBrush" Color="#9AA3AF" />
        <SolidColorBrush x:Key="HeaderInfoValueBrush" Color="#667085" />
        <SolidColorBrush x:Key="HeaderHoverBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="HeaderPressedBrush" Color="#F1F5F9" />
        <SolidColorBrush x:Key="HeaderSeparatorBrush" Color="#EEF0F2" />

        <Style x:Key="HeaderButtonBase" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderOutlineButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="HeaderGhostButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="HeaderReviewToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HeaderHoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="Background" Value="#DCFCE7" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunInProgress}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderIconButton" TargetType="Button" BasedOn="{StaticResource HeaderButtonBase}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
        </Style>

        <Style x:Key="HeaderToolIcon" TargetType="TextBlock" BasedOn="{StaticResource IconText}">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Opacity" Value="0.92" />
        </Style>

        <Style x:Key="HeaderRunIcon" TargetType="TextBlock" BasedOn="{StaticResource HeaderToolIcon}">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0,0,9,0" />
        </Style>

        <Style x:Key="HeaderIconOnlyText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderToolText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoLabelBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderInfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource HeaderInfoValueBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="HeaderExportMenuItem" TargetType="MenuItem">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BorderBrushSoft}"
            Padding="16,6">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource HeaderOutlineButton}"
                        Command="{Binding RunSelectedJobCommand}"
                        ToolTip="{Binding RunPreflightDetail}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE768;" Style="{StaticResource HeaderRunIcon}" />
                        <TextBlock Text="実行" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HeaderOutlineButton}"
                        Command="{Binding CancelCommand}"
                        ToolTip="実行中の処理を中止">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE739;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="中止" Style="{StaticResource HeaderToolText}" />
                    </StackPanel>
                </Button>

                <ToggleButton Style="{StaticResource HeaderReviewToggle}"
                              IsChecked="{Binding EnableReviewStage, Mode=TwoWay}"
                              ToolTip="{Binding ReviewStageToggleToolTip}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE70F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ReviewStageToggleText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <Button x:Name="ExportMenuButton"
                        Style="{StaticResource HeaderGhostButton}"
                        MinWidth="132"
                        Click="OnExportMenuButtonClick"
                        ToolTip="エクスポートメニュー">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="素起こし" Style="{StaticResource HeaderExportMenuItem}">
                                <MenuItem Header="TXT" Command="{Binding ExportRawTxtCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="Markdown" Command="{Binding ExportRawMarkdownCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="JSON" Command="{Binding ExportRawJsonCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="SRT" Command="{Binding ExportRawSrtCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="VTT" Command="{Binding ExportRawVttCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="DOCX" Command="{Binding ExportRawDocxCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                            </MenuItem>
                            <MenuItem Header="整文" Style="{StaticResource HeaderExportMenuItem}">
                                <MenuItem Header="TXT" Command="{Binding ExportPolishedTxtCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="Markdown" Command="{Binding ExportPolishedMarkdownCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="DOCX" Command="{Binding ExportPolishedDocxCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                            </MenuItem>
                            <MenuItem Header="要約" Style="{StaticResource HeaderExportMenuItem}">
                                <MenuItem Header="Markdown" Command="{Binding ExportSummaryMarkdownCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                                <MenuItem Header="TXT" Command="{Binding ExportSummaryTextCommand}" Style="{StaticResource HeaderExportMenuItem}" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="タイムスタンプを含める"
                                      IsCheckable="True"
                                      IsChecked="{Binding IncludeExportTimestamps, Mode=TwoWay}"
                                      Style="{StaticResource HeaderExportMenuItem}" />
                            <Separator />
                            <MenuItem Header="出力フォルダーを開く"
                                      Command="{Binding OpenExportFolderCommand}"
                                      Style="{StaticResource HeaderExportMenuItem}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE78F;" Style="{StaticResource HeaderToolIcon}" />
                        <TextBlock Text="エクスポート" Style="{StaticResource HeaderToolText}" />
                        <TextBlock Text="&#xE70D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource HeaderInfoValueBrush}"
                                   FontSize="11"
                                   Margin="9,1,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <Button Style="{StaticResource HeaderIconButton}"
                            Command="{Binding ZoomOutCommand}"
                            ToolTip="{Binding MainContentZoomToolTip}">
                        <TextBlock Text="&#xE71F;" Style="{StaticResource HeaderIconOnlyText}" />
                    </Button>
                    <Button Style="{StaticResource HeaderGhostButton}"
                            Command="{Binding ResetZoomCommand}"
                            Padding="8,0"
                            MinWidth="52"
                            ToolTip="表示倍率を100%に戻す">
                        <TextBlock Text="{Binding MainContentZoomPercentText}"
                                   Style="{StaticResource HeaderToolText}"
                                   FontSize="11" />
                    </Button>
                    <Button Style="{StaticResource HeaderIconButton}"
                            Command="{Binding ZoomInCommand}"
                            ToolTip="{Binding MainContentZoomToolTip}">
                        <TextBlock Text="&#xE8A3;" Style="{StaticResource HeaderIconOnlyText}" />
                    </Button>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="12,0,12,0">
                <TextBlock Text="VERSION" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding AppVersionDisplay}"
                           Style="{StaticResource HeaderInfoValue}"
                           ToolTip="{Binding AppVersionToolTip}"
                           Margin="0,0,12,0" />
                <TextBlock Text="ASR" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding AsrModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="118"
                           ToolTip="{Binding AsrModel}"
                           Margin="0,0,12,0" />
                <TextBlock Text="整文" Style="{StaticResource HeaderInfoLabel}" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ReviewModel}"
                           Style="{StaticResource HeaderInfoValue}"
                           MaxWidth="96"
                           ToolTip="{Binding ReviewModel}" />
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <Border Width="0.5"
                        Height="24"
                        Background="{StaticResource HeaderSeparatorBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="設定">
                    <TextBlock Text="&#xE713;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenSetupCommand}"
                        ToolTip="{Binding SetupPlaceholderText}">
                    <TextBlock Text="&#xE9D9;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding ShowModelCatalogCommand}"
                        ToolTip="モデル">
                    <TextBlock Text="&#xE8B7;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding OpenLogsCommand}"
                        ToolTip="ログ">
                    <TextBlock Text="&#xE8A5;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
                <Button Style="{StaticResource HeaderIconButton}"
                        Command="{Binding CheckForUpdatesCommand}"
                        ToolTip="更新を確認">
                    <TextBlock Text="&#xE895;" Style="{StaticResource HeaderIconOnlyText}" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
