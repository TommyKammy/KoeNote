<UserControl x:Class="KoeNote.App.Controls.JobListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FFFFFF" Padding="12,14">
        <DockPanel>
            <Grid DockPanel.Dock="Top" MinHeight="38" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource LucideCardIconBadge}">
                        <Path Style="{StaticResource LucidePathIcon}"
                              Data="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16M4 6h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2" />
                    </Border>
                    <TextBlock Text="ジョブ"
                               Style="{StaticResource SectionTitle}"
                               Margin="0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="クリア"
                        Command="{Binding ClearAllJobsCommand}"
                        Padding="10,4"
                        MinHeight="30"
                        ToolTip="ジョブ一覧をクリア履歴へ移動" />
            </Grid>

            <Grid DockPanel.Dock="Top"
                  MaxWidth="200"
                  Height="28"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,12"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="OnJobSearchBoxPreviewMouseLeftButtonDown">
                <Border Background="#FFFFFF"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14" />
                <TextBox x:Name="JobSearchTextBox"
                         Style="{StaticResource SearchPillTextBox}"
                         Text="{Binding JobSearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="ジョブ名で検索" />
                <Grid Width="14"
                      Height="14"
                      Margin="12,0,0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"
                      Panel.ZIndex="1">
                    <Ellipse Width="8"
                             Height="8"
                             Stroke="#2563EB"
                             StrokeThickness="1.7"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Margin="1.5,1.5,0,0" />
                    <Path Data="M8.6 8.6 L12.5 12.5"
                          Stroke="{StaticResource MutedBrush}"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round" />
                </Grid>
                <TextBlock Text="ジョブを検索"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="36,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=JobSearchTextBox}" Value="" />
                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=JobSearchTextBox}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Content="x"
                        Command="{Binding ClearJobSearchCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SearchClearButton}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=JobSearchTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <TabControl Style="{StaticResource CardTabControl}">
                <TabItem Header="一覧">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding JobCountSummary}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,12" />
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <DockPanel>
                        <Border DockPanel.Dock="Bottom"
                                Background="#FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="8"
                                Margin="0,14,0,0"
                                Cursor="Hand"
                                AllowDrop="True"
                                MouseLeftButtonUp="OnImportDropZoneClick"
                                ToolTip="音声ファイルをドラッグ&amp;ドロップ、またはクリックして選択">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFFFFF" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FAFBFC" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid MinHeight="88">
                                <Rectangle RadiusX="8"
                                           RadiusY="8"
                                           Stroke="#CBD5E1"
                                           StrokeThickness="1"
                                           StrokeDashArray="4 4"
                                           Fill="Transparent"
                                           IsHitTestVisible="False" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Width="22"
                                          Height="18"
                                          Stretch="Uniform"
                                          Fill="#FBBF24"
                                          Data="M3 5.5C3 4.67 3.67 4 4.5 4H8L9.6 5.7H15.5C16.33 5.7 17 6.37 17 7.2V7.8H3V5.5ZM2 8.6C2 7.77 2.67 7.1 3.5 7.1H18.5C19.38 7.1 20.05 7.89 19.9 8.76L18.7 15.46C18.57 16.18 17.94 16.7 17.21 16.7H4.79C4.06 16.7 3.43 16.18 3.3 15.46L2.1 8.76C2.04 8.71 2 8.66 2 8.6Z"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,9" />
                                    <TextBlock Text="ファイルをドロップ"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"
                                               FontWeight="Normal"
                                               TextAlignment="Center"
                                               Margin="0,0,0,3" />
                                    <TextBlock Text="またはクリックして選択"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               TextDecorations="Underline"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ListBox ItemsSource="{Binding FilteredJobs}"
                                 SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                                 Style="{StaticResource CardListBox}"
                                 ItemContainerStyle="{StaticResource CardListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14"
                                            Background="#FFFFFF"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" />
                                                <Button Grid.Column="1"
                                                        Content="&#xE74D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        Command="{Binding DataContext.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="6,2"
                                                        MinWidth="28"
                                                        ToolTip="このジョブをクリア履歴へ移動" />
                                            </Grid>
                                            <TextBlock Text="{Binding FileName}"
                                                       Style="{StaticResource MutedText}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Margin="0,0,0,12" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="7"
                                                            Height="7"
                                                            CornerRadius="4"
                                                            Background="{StaticResource AccentBrush}"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,7,0" />
                                                    <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedBrush}" />
                                            </Grid>
                                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Margin="0,0,0,12" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding UpdatedAtDisplay}" Style="{StaticResource MutedText}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding UnreviewedDrafts, StringFormat=未確認 {0}}"
                                                           Style="{StaticResource MutedText}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </TabItem>

                <TabItem Header="クリア履歴">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DeletedJobCountSummary}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="完全削除"
                                    Command="{Binding PermanentlyDeleteAllDeletedJobsCommand}"
                                    Padding="10,4"
                                    MinHeight="30"
                                    ToolTip="クリア履歴のジョブと関連ファイルを完全削除" />
                        </Grid>
                        <ListBox ItemsSource="{Binding FilteredDeletedJobs}"
                                 Style="{StaticResource CardListBox}"
                                 ItemContainerStyle="{StaticResource CardListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10"
                                            Background="#FFFFFF"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedText}" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,0,8" />
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DeletedAtDisplay, StringFormat=クリア {0}}" Style="{StaticResource MutedText}" />
                                                <TextBlock Grid.Column="1" Text="{Binding StorageSizeDisplay, StringFormat={}{0}}" Style="{StaticResource MutedText}" />
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="復元"
                                                        Command="{Binding DataContext.RestoreJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3"
                                                        MinHeight="26"
                                                        Margin="0,0,6,0" />
                                                <Button Content="完全削除"
                                                        Command="{Binding DataContext.PermanentlyDeleteJobCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3"
                                                        MinHeight="26" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</UserControl>
