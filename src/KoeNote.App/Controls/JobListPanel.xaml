<UserControl x:Class="KoeNote.App.Controls.JobListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="ジョブ一覧" Style="{StaticResource SectionTitle}" />
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedBrush}" Margin="12,0,0,0" VerticalAlignment="Center" Panel.ZIndex="1" />
                        <TextBox Text="{Binding JobSearchText, UpdateSourceTrigger=PropertyChanged}" Padding="32,7,10,7" MinHeight="34" ToolTip="ジョブ名で検索" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding JobCountSummary}" Style="{StaticResource MutedText}" Margin="0,0,0,12" />

                    <ListBox ItemsSource="{Binding FilteredJobs}"
                             SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                             Style="{StaticResource CardListBox}"
                             ItemContainerStyle="{StaticResource CardListBoxItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                            <Button Padding="6,2" MinWidth="0">
                                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedBrush}" />
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="{Binding FileName}" Style="{StaticResource MutedText}" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,0,12" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="7" Height="7" CornerRadius="4" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                                <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                        </Grid>
                                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Margin="0,0,0,12" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding UpdatedAtDisplay}" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding UnreviewedDrafts, StringFormat=未レビュー {0}}" Style="{StaticResource MutedText}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
</UserControl>
