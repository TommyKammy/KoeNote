<UserControl x:Class="KoeNote.App.Controls.TranscriptAudioPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <UserControl.Resources>
        <Style x:Key="PlayerRoundButton" TargetType="Button" BasedOn="{StaticResource PlayerIconButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PlayerPrimaryButton" TargetType="Button" BasedOn="{StaticResource PlayerIconButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFFFFF"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            MinHeight="116"
            Padding="14,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34"
                            Height="34"
                            CornerRadius="7"
                            Background="{StaticResource AccentLightBrush}"
                            Margin="0,0,10,0">
                        <TextBlock Text="&#xEC4F;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="17"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <TextBlock Text="{Binding SelectedJobSourcePath}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding SelectedJobSourcePath}"
                                   MaxWidth="520" />
                        <TextBlock Text="{Binding PlaybackTimeDisplay}"
                                   Style="{StaticResource MutedText}"
                                   FontSize="11"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <TextBlock Text="{Binding PlaybackVolumeIcon}"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <Slider Width="92"
                            Minimum="0"
                            Maximum="1"
                            Value="{Binding PlaybackVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            ToolTip="音量" />
                    <ComboBox Style="{StaticResource ToolbarComboBox}"
                              Width="76"
                              Height="34"
                              Margin="10,0,0,0"
                              ItemsSource="{Binding PlaybackRates}"
                              SelectedItem="{Binding PlaybackRate, Mode=TwoWay}"
                              ItemStringFormat="{}{0:0.##}x"
                              ToolTip="再生速度" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToPreviousSegmentCommand}"
                            ToolTip="前のセグメントへ">
                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                    <Button Style="{StaticResource PlayerPrimaryButton}"
                            Command="{Binding PlayPauseAudioCommand}"
                            ToolTip="{Binding SelectedJobPlaybackPath}"
                            Margin="6,0">
                        <TextBlock Text="{Binding PlayPauseAudioIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="#FFFFFF" />
                    </Button>
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToNextSegmentCommand}"
                            ToolTip="次のセグメントへ">
                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8"
                        VerticalAlignment="Stretch">
                    <controls:AudioWaveformControl Samples="{Binding PlaybackWaveformSamples}"
                                                    PositionSeconds="{Binding PlaybackPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    DurationSeconds="{Binding PlaybackDurationSeconds}"
                                                    Height="42"
                                                    Cursor="Hand"
                                                    ToolTip="{Binding SelectedJobPlaybackPath}" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
