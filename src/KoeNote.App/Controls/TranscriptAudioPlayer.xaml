<UserControl x:Class="KoeNote.App.Controls.TranscriptAudioPlayer"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:KoeNote.App.Controls">
    <UserControl.Resources>
        <Style x:Key="PlayerRoundButton" TargetType="Button" BasedOn="{StaticResource PlayerIconButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#EEF0F3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlayerPrimaryButton" TargetType="Button" BasedOn="{StaticResource PlayerIconButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#16A34A"
                                                  BlurRadius="8"
                                                  ShadowDepth="2"
                                                  Opacity="0.28" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#15803D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#166534" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlayerSlimPrimaryButton" TargetType="Button" BasedOn="{StaticResource PlayerPrimaryButton}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style x:Key="PlayerTimeText" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="VisibleWhenSlimPlayer" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSlim, ElementName=Root}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenFullPlayer" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSlim, ElementName=Root}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="0"
                MinHeight="72"
                Padding="14,12"
                Style="{StaticResource VisibleWhenFullPlayer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToPreviousSegmentCommand}"
                            ToolTip="前のセグメントへ">
                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </Button>
                    <Button Style="{StaticResource PlayerPrimaryButton}"
                            Command="{Binding PlayPauseAudioCommand}"
                            ToolTip="{Binding SelectedJobPlaybackPath}"
                            Margin="6,0">
                        <TextBlock Text="{Binding PlayPauseAudioIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17"
                                   Foreground="#FFFFFF" />
                    </Button>
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToNextSegmentCommand}"
                            ToolTip="次のセグメントへ">
                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <TextBlock Text="{Binding SelectedJobFileName}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedJobSourcePath}" />
                    <TextBlock Text="{Binding PlaybackTimeDisplay}"
                               Style="{StaticResource PlayerTimeText}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <controls:AudioWaveformControl Grid.Column="2"
                                                Samples="{Binding PlaybackWaveformSamples}"
                                                PositionSeconds="{Binding PlaybackPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                DurationSeconds="{Binding PlaybackDurationSeconds}"
                                                Height="30"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding SelectedJobPlaybackPath}" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text="{Binding PlaybackVolumeIcon}"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0" />
                    <Slider Width="52"
                            Minimum="0"
                            Maximum="1"
                            Value="{Binding PlaybackVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            ToolTip="音量" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="0,0,10,10"
                MinHeight="56"
                Padding="14,7"
                Style="{StaticResource VisibleWhenSlimPlayer}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToPreviousSegmentCommand}"
                            ToolTip="前のセグメントへ">
                        <TextBlock Text="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource PlayerSlimPrimaryButton}"
                            Command="{Binding PlayPauseAudioCommand}"
                            ToolTip="{Binding SelectedJobPlaybackPath}"
                            Margin="5,0">
                        <TextBlock Text="{Binding PlayPauseAudioIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="17"
                                   Foreground="#FFFFFF" />
                    </Button>
                    <Button Style="{StaticResource PlayerRoundButton}"
                            Command="{Binding SkipToNextSegmentCommand}"
                            ToolTip="次のセグメントへ">
                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding PlaybackTimeDisplay}"
                           Style="{StaticResource PlayerTimeText}"
                           MinWidth="92"
                           TextAlignment="Center"
                           Margin="0,0,14,0" />

                <controls:AudioWaveformControl Grid.Column="2"
                                                Samples="{Binding PlaybackWaveformSamples}"
                                                PositionSeconds="{Binding PlaybackPositionSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                DurationSeconds="{Binding PlaybackDurationSeconds}"
                                                Height="24"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding SelectedJobPlaybackPath}" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <TextBlock Text="{Binding PlaybackVolumeIcon}"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <Slider Width="64"
                            Minimum="0"
                            Maximum="1"
                            Value="{Binding PlaybackVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            ToolTip="音量" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
