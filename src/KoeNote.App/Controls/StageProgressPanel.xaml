<UserControl x:Class="KoeNote.App.Controls.StageProgressPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="処理ステージ" Style="{StaticResource SectionTitle}" />
                    <ItemsControl ItemsSource="{Binding StageStatuses}">
                        <ItemsControl.Resources>
                            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                        </ItemsControl.Resources>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Height="48">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Height="2"
                                                Background="{StaticResource BorderBrushSoft}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ShowConnectorBefore, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Border Grid.Column="2"
                                                Height="2"
                                                Background="{StaticResource BorderBrushSoft}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ShowConnectorAfter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Border HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Grid.Column="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="20" />
                                                    <Setter Property="Width" Value="40" />
                                                    <Setter Property="Height" Value="40" />
                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                    <Setter Property="BorderBrush" Value="#E5E7EB" />
                                                    <Setter Property="Background" Value="#FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Background" Value="{Binding IconStroke}" />
                                                            <Setter Property="BorderBrush" Value="{Binding IconStroke}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDoing}" Value="True">
                                                            <Setter Property="Background" Value="{Binding IconSoftBackground}" />
                                                            <Setter Property="BorderBrush" Value="{Binding IconStroke}" />
                                                            <Setter Property="BorderThickness" Value="2.5" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Width="40"
                                                  Height="40"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Border Margin="4"
                                                        CornerRadius="16"
                                                        BorderThickness="1"
                                                        BorderBrush="#24FFFFFF"
                                                        Background="#18FFFFFF" />
                                                <Viewbox Width="21" Height="21" Stretch="Uniform"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                    <Grid Width="24" Height="24">
                                                        <Path Data="{Binding IconPathData}"
                                                              Stretch="None"
                                                              StrokeThickness="1.75"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="#CBD5E1" />
                                                                    <Setter Property="Opacity" Value="0.72" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                            <Setter Property="Stroke" Value="#FFFFFF" />
                                                                            <Setter Property="Opacity" Value="1" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsDoing}" Value="True">
                                                                            <Setter Property="Stroke" Value="{Binding IconStroke}" />
                                                                            <Setter Property="Opacity" Value="1" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Name}"
                                               TextAlignment="Center"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Margin="0,6,0,2" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Status}"
                                               TextAlignment="Center"
                                               Style="{StaticResource MutedText}"
                                               FontSize="10.5"
                                               FontWeight="Normal" />
                                    <TextBlock Grid.Row="3"
                                               Text="{Binding DurationText}"
                                               TextAlignment="Center"
                                               Foreground="#888888"
                                               FontSize="10"
                                               FontWeight="Light"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

</UserControl>
