<UserControl x:Class="KoeNote.App.Controls.StageProgressPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Border Style="{StaticResource PanelBorder}" Padding="12,9">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="処理ステージ"
                               Style="{StaticResource SectionTitle}"
                               FontSize="15"
                               Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding StageStatuses}">
                        <ItemsControl.Resources>
                            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
                            <Style x:Key="StageToggleButtonStyle" TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="HoverGlow"
                                                    Width="36"
                                                    Height="36"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="18"
                                                    Background="#1033A06F"
                                                    BorderBrush="#4EBB8A"
                                                    BorderThickness="1.5"
                                                    Opacity="0" />
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HoverGlow" Property="Opacity" Value="1" />
                                                    <Setter TargetName="HoverGlow" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#33A06F"
                                                                              BlurRadius="18"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.55" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="HoverGlow" Property="Opacity" Value="0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ItemsControl.Resources>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Height="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Height="2"
                                                Background="{StaticResource BorderBrushSoft}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ShowConnectorBefore, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Border Grid.Column="2"
                                                Height="2"
                                                Background="{StaticResource BorderBrushSoft}"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ShowConnectorAfter, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Border HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Grid.Column="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="20" />
                                                    <Setter Property="Width" Value="36" />
                                                    <Setter Property="Height" Value="36" />
                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                    <Setter Property="BorderBrush" Value="#E5E7EB" />
                                                    <Setter Property="Background" Value="#FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Background" Value="{Binding IconStroke}" />
                                                            <Setter Property="BorderBrush" Value="{Binding IconStroke}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDoing}" Value="True">
                                                            <Setter Property="Background" Value="{Binding IconSoftBackground}" />
                                                            <Setter Property="BorderBrush" Value="{Binding IconStroke}" />
                                                            <Setter Property="BorderThickness" Value="2.5" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSkipped}" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC" />
                                                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Width="36"
                                                  Height="36"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Border Margin="4"
                                                        CornerRadius="16"
                                                        BorderThickness="1"
                                                        BorderBrush="#24FFFFFF"
                                                        Background="#18FFFFFF" />
                                                <Viewbox Width="19" Height="19" Stretch="Uniform"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                    <Grid Width="24" Height="24">
                                                        <Path Data="{Binding IconPathData}"
                                                              Stretch="None"
                                                              StrokeThickness="1.75"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="#CBD5E1" />
                                                                    <Setter Property="Opacity" Value="0.72" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                            <Setter Property="Stroke" Value="#FFFFFF" />
                                                                            <Setter Property="Opacity" Value="1" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsDoing}" Value="True">
                                                                            <Setter Property="Stroke" Value="{Binding IconStroke}" />
                                                                            <Setter Property="Opacity" Value="1" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsSkipped}" Value="True">
                                                                            <Setter Property="Stroke" Value="#94A3B8" />
                                                                            <Setter Property="Opacity" Value="0.55" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Width="36"
                                                Height="36"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Padding="0"
                                                Cursor="Hand"
                                                Focusable="False"
                                                Style="{StaticResource StageToggleButtonStyle}"
                                                IsHitTestVisible="{Binding IsToggleable}"
                                                Command="{Binding DataContext.ToggleReviewStageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding ToggleToolTip}" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Name}"
                                               TextAlignment="Center"
                                               FontSize="11.5"
                                               FontWeight="Bold"
                                               Margin="0,4,0,1" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Status}"
                                               TextAlignment="Center"
                                               Style="{StaticResource MutedText}"
                                               FontSize="10"
                                               FontWeight="Normal" />
                                    <TextBlock Grid.Row="3"
                                               Text="{Binding DurationText}"
                                               TextAlignment="Center"
                                               Foreground="#888888"
                                               FontSize="9.5"
                                               FontWeight="Light"
                                               Margin="0,1,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

</UserControl>
