<UserControl x:Class="KoeNote.App.Controls.ModelCatalogTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ModelSection" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="ModelFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="ModelActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
        <Style x:Key="ModelCardItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.08*" MinWidth="280" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="0.92*" MinWidth="240" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource ModelSection}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="モデル一覧"
                               Style="{StaticResource SectionTitle}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="ASR と整文の利用モデルを確認し、必要なモデルを導入できます。"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox ItemsSource="{Binding ModelCatalogEntries}"
                         SelectedItem="{Binding SelectedModelCatalogEntry, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource ModelCardItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,2" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding InstallState}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Top" />

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Role}"
                                               Foreground="#334155"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,12,0" />
                                    <TextBlock Text="{Binding SizeSummary}"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,0,12,0" />
                                    <TextBlock Text="{Binding DownloadProgressSummary}"
                                               Style="{StaticResource MutedText}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding QualityLabelSummary}"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis" />

                                <ProgressBar Grid.Row="2"
                                             Grid.Column="1"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding DownloadProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsDownloadProgressIndeterminate}"
                                             Visibility="{Binding IsDownloadActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Width="88"
                                             Height="6"
                                             Margin="12,8,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource ModelSection}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedModelCatalogEntry.DisplayName}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding SelectedModelCatalogEntry.Role}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,12" />

                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="状態" Style="{StaticResource ModelFieldLabel}" />
                                <TextBlock Text="{Binding SelectedModelCatalogEntry.InstallState}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="サイズ" Style="{StaticResource ModelFieldLabel}" />
                                <TextBlock Text="{Binding SelectedModelCatalogEntry.SizeSummary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="ライセンス" Style="{StaticResource ModelFieldLabel}" />
                                <TextBlock Text="{Binding SelectedModelCatalogEntry.LicenseName}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="ダウンロード" Style="{StaticResource ModelFieldLabel}" />
                                <TextBlock Text="{Binding SelectedModelCatalogEntry.DownloadProgressSummary}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="実行要件" Style="{StaticResource ModelFieldLabel}" />
                        <TextBlock Text="{Binding SelectedModelCatalogEntry.RuntimeRequirement}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="品質ラベル" Style="{StaticResource ModelFieldLabel}" />
                        <TextBlock Text="{Binding SelectedModelCatalogEntry.QualityLabelSummary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     Value="{Binding SelectedModelCatalogEntry.DownloadProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{Binding SelectedModelCatalogEntry.IsDownloadProgressIndeterminate}"
                                     Visibility="{Binding SelectedModelCatalogEntry.IsDownloadActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Height="8"
                                     Margin="0,0,0,8" />

                        <TextBlock Text="{Binding SelectedModelCatalogEntry.DownloadError}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModelSection}">
                    <StackPanel>
                        <TextBlock Text="操作"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0,0,0,10" />

                        <WrapPanel>
                            <Button Command="{Binding DownloadSelectedModelCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="ダウンロード" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding UseSelectedModelCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="使用する" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowSelectedModelLicenseCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="ライセンス" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RegisterPreinstalledModelsCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="再検出" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PauseSelectedModelDownloadCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE769;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="一時停止" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ResumeSelectedModelDownloadCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="再開" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RetrySelectedModelDownloadCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="再試行" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CancelSelectedModelDownloadCommand}"
                                    Style="{StaticResource ModelActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="中止" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteSelectedModelFilesCommand}"
                                    Style="{StaticResource ModelActionButton}"
                                    ToolTip="選択したモデルファイルと導入済み登録を削除します。">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="モデルファイルを削除" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
