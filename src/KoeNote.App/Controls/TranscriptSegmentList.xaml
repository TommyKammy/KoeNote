<UserControl x:Class="KoeNote.App.Controls.TranscriptSegmentList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <DockPanel.Resources>
            <Style x:Key="VisibleWhenRawTranscriptMode" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenPolishedTranscriptMode" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Polished">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VisibleWhenDiffTranscriptMode" TargetType="FrameworkElement">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Diff">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DockPanel.Resources>

        <Border DockPanel.Dock="Top"
                Background="#F7FCF9"
                BorderBrush="#B7D8C4"
                BorderThickness="1"
                CornerRadius="0"
                Padding="12"
                Margin="0,0,0,10"
                Style="{StaticResource VisibleWhenRawTranscriptMode}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="原文確認・修正"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="話者名や本文に違和感がある場合だけ、ここで原文を修正します。修正後はジョブ全体から再整文できます。"
                               Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0">
                    <Button Command="{Binding RunPostReviewCommand}"
                            Content="レビュー候補を再生成"
                            Padding="12,6"
                            MinWidth="0"
                            Margin="0,0,8,0"
                            ToolTip="修正済み原文からレビュー候補を再生成します" />
                    <Button Command="{Binding RunReadablePolishingCommand}"
                            Padding="12,6"
                            MinWidth="0"
                            Style="{StaticResource OutlineSuccessButton}"
                            ToolTip="修正済み原文から整文を再生成します">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;"
                                       Style="{StaticResource IconText}"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="この原文から再整文"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="#FAFBFC"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="16,8"
                Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="時間" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="話者" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="素起こし" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Style="{StaticResource VisibleWhenRawTranscriptMode}" />
                <TextBlock Grid.Column="2" Text="レビュー候補" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Style="{StaticResource VisibleWhenPolishedTranscriptMode}" />
                <TextBlock Grid.Column="2" Text="差分" Foreground="#64748B" FontSize="12" FontWeight="SemiBold" Style="{StaticResource VisibleWhenDiffTranscriptMode}" />
            </Grid>
        </Border>

        <ListBox x:Name="SegmentList"
                 ItemsSource="{Binding FilteredSegments}"
                 SelectedItem="{Binding SelectedSegment, Mode=TwoWay}"
                 Style="{StaticResource CardListBox}"
                 ItemContainerStyle="{StaticResource SegmentListBoxItem}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DataTemplate.Resources>
                        <Style x:Key="InlineDisplayTextStyle" TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw" />
                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True" />
                                        <Condition Binding="{Binding DataContext.IsSegmentInlineEditActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="InlineEditorStyle" TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw" />
                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True" />
                                        <Condition Binding="{Binding DataContext.IsSegmentInlineEditActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="SpeakerDisplayStyle" TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="ToolTip" Value="{x:Null}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw">
                                    <Setter Property="Cursor" Value="IBeam" />
                                    <Setter Property="ToolTip" Value="クリックして話者名を編集" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw" />
                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True" />
                                        <Condition Binding="{Binding DataContext.IsSpeakerInlineEditActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="SpeakerEditorStyle" TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Raw" />
                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True" />
                                        <Condition Binding="{Binding DataContext.IsSpeakerInlineEditActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataTemplate.Resources>

                    <Border Padding="16,13"
                            Background="Transparent"
                            BorderBrush="#EEF1F3"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Start}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Top" />
                            <Border Grid.Column="1"
                                    Background="#F1F5F9"
                                    CornerRadius="12"
                                    Padding="9,4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    MouseLeftButtonDown="OnSpeakerMouseLeftButtonDown"
                                    Style="{StaticResource SpeakerDisplayStyle}">
                                <TextBlock Text="{Binding Speaker}" FontSize="12" Foreground="#475569" />
                            </Border>
                            <TextBox Grid.Column="1"
                                     Tag="InlineSpeakerEditor"
                                     Text="{Binding DataContext.SelectedSpeakerAlias, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30"
                                     MinWidth="78"
                                     MaxWidth="92"
                                     Padding="7,4"
                                     FontSize="12"
                                     VerticalAlignment="Top"
                                     LostKeyboardFocus="OnInlineSpeakerEditorLostKeyboardFocus"
                                     ToolTip="話者名を編集します。別の場所をクリックすると自動保存されます。"
                                     Style="{StaticResource SpeakerEditorStyle}" />

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       FontSize="14"
                                       FontWeight="Normal"
                                       LineHeight="22"
                                       Style="{StaticResource InlineDisplayTextStyle}"
                                       MouseLeftButtonDown="OnSegmentTextMouseLeftButtonDown" />
                            <Grid Grid.Column="2"
                                  Style="{StaticResource VisibleWhenDiffTranscriptMode}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="素起こし"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding RawTranscriptText}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="Normal"
                                                   LineHeight="21" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1"
                                        Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Margin="0,6">
                                    <TextBlock Text="{Binding TranscriptDiffStatus}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Grid.Row="2"
                                        Background="#F7FCF9"
                                        BorderBrush="#B7D8C4"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="レビュー候補"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding PolishedTranscriptText}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="Normal"
                                                   LineHeight="21" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Grid Grid.Column="2" Style="{StaticResource InlineEditorStyle}">
                                <TextBox Tag="InlineSegmentEditor"
                                         Text="{Binding DataContext.SelectedSegmentEditText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="54"
                                         Padding="10,8"
                                         VerticalContentAlignment="Top"
                                         LostKeyboardFocus="OnInlineSegmentEditorLostKeyboardFocus"
                                         ToolTip="選択中のセグメントを編集します。別の場所をクリックすると自動保存されます。" />
                            </Grid>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource VisibleWhenRawTranscriptMode}">
                                <Button Width="24"
                                        Height="24"
                                        Padding="0"
                                        Margin="4,0,0,0"
                                        ToolTip="セグメントを編集"
                                        Command="{Binding DataContext.BeginSegmentInlineEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                                <Button Width="24"
                                        Height="24"
                                        Padding="0"
                                        Margin="4,0,0,0"
                                        Tag="InlineSegmentRevertButton"
                                        ToolTip="編集前に戻す"
                                        PreviewMouseDown="OnInlineSegmentRevertPreviewMouseDown"
                                        Command="{Binding DataContext.RevertSegmentEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
