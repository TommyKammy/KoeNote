{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koenote.local/schemas/domain-preset.schema.json",
  "title": "KoeNote Domain Preset",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "preset_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "asr_context": {
      "type": "string"
    },
    "hotwords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "correction_memory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["wrong_text", "correct_text"],
        "properties": {
          "wrong_text": {
            "type": "string",
            "minLength": 1
          },
          "correct_text": {
            "type": "string",
            "minLength": 1
          },
          "issue_type": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "default": "global"
          }
        }
      }
    },
    "speaker_aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["speaker_id", "display_name"],
        "properties": {
          "job_id": {
            "type": "string",
            "description": "省略時のインポートでは、選択中のジョブへ適用されます。"
          },
          "speaker_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_guidelines": {
      "type": "array",
      "description": "推敲レビューのプロンプトへ追加される専門領域のレビュー指針です。",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "anyOf": [
    {
      "required": ["asr_context"]
    },
    {
      "required": ["hotwords"]
    },
    {
      "required": ["correction_memory"]
    },
    {
      "required": ["speaker_aliases"]
    },
    {
      "required": ["review_guidelines"]
    }
  ]
}
